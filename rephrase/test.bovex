let
  import "stdlib.bovex"

  import "layout.bovex"
  import "cite.bovex"
  import "paper.bib"

  val VERBOSE = false

  val author = b[Tom 7 [[Murphy]] ]

  fun attrs-string (BOX, {(Box) width }) = "box-width"
    | attrs-string (BOX, _) = "box"
    | attrs-string (SPAN, {(Span) font-face}) = "span(" ^ font-face ^ ")"
    | attrs-string (SPAN, {(Span) font-bold}) =
    if font-bold then "span-bold" else "span-nobold"
    | attrs-string (SPAN, _) = "span"
    | attrs-string (STICKER, _) = "sticker"
    | attrs-string (GROUP, _) = "group"

  fun printlayout l =
    case layoutcase l of
      Text s => print (s ^ "\n")
    | Node (display, obj, children) =>
        let in
          print "node ";
          print (attrs-string (display, obj));
          print (" with " ^ (int-to-string (list-length children)) ^
                    " children:\n");
          list-app printlayout children
        end

  do VERBOSE andthen printlayout author

  fun test-get-paragraphs () =
    let
      val s = get-paragraphs ([word] :: nil)
      do case s of
        p :: nil =>
          let
            val w = get-text-rec p
          in
            string-eq (w, "word")
            otherwise fail ("wrong result: " ^ w)
          end
      | nil => fail "there were no paragraphs?"
      | _ => fail "expected one paragraph"
    in
      ()
    end
  do test-get-paragraphs ()

  (* Generally just one of these, for the toplevel document.
     This breaks the layout into paragraphs, and then inserts
     them one by one into columns. *)
  fun main-text lay =
    let
      val PAGE-WIDTH = inch 8.5
      val PAGE-HEIGHT = inch 11.0
      val LEFT-MARGIN = inch 0.3
      val TOP-MARGIN = inch 0.5
      val GUTTER = inch 0.25
      val COLUMNS = 2
      do COLUMNS >= 1 otherwise fail "There must be at least one column!"
      val RIGHT-MARGIN = inch 0.3
      val BOTTOM-MARGIN = inch 0.5

      val BODY-WIDTH = PAGE-WIDTH -. (LEFT-MARGIN +. RIGHT-MARGIN)
      val BODY-HEIGHT = PAGE-HEIGHT -. (TOP-MARGIN +. BOTTOM-MARGIN)
      val COLUMN-WIDTH =
        (BODY-WIDTH -. (int-to-float (COLUMNS - 1) *. GUTTER))
        /. (int-to-float COLUMNS)

      val LEFT-COLUMN-X = LEFT-MARGIN
      val COLUMN-STRIDE = COLUMN-WIDTH +. GUTTER

      (* XXX This should depend on the font *)
      val PARAGRAPH-VSPACE-BOTTOM = 12.0

      val current-page = ref 0

      (* Layout state. *)
      val current-column = ref 0
      (* y position within column. *)
      val current-ypos = ref 0.0
      val column-empty = ref true

      val column-stickers-rev : layout list ref = ref nil
      fun add-column-sticker s =
        let in
          column-empty := false;
          column-stickers-rev := s :: !column-stickers-rev
        end

      (* Emits the current column (if non-empty); clears it. *)
      fun emit-column () =
        let
          val colx =
            LEFT-COLUMN-X +.
            ((int-to-float (!current-column)) *. COLUMN-STRIDE)
        in
          !column-empty otherwise
          output (!current-page,
                  sticker ({(Sticker)
                            x = colx ,
                            y = TOP-MARGIN }
                           with column-num = !current-column
                           with comment = "column"
                           with column-stride = COLUMN-STRIDE
                           with left-margin = LEFT-MARGIN)
                  (layout-concat (list-rev (!column-stickers-rev))));
          column-stickers-rev := nil;
          column-empty := true
        end

      (* XXX should probably just use pack-boxes for this, but
         they are vertical boxes. *)
      fun insert-paragraph (p : layout) : unit =
        let
          do VERBOSE andthen
            let in
              print "----insert para----\n";
              debug-print-doc p;
              print "-------------------\n"
            end

          val boxes = get-boxes p

          do VERBOSE andthen
            let in
              print "----the boxes...---\n";
              debug-print-doc boxes;
              print "-------------------\n"
            end

          val lines : layout list = pack-boxes (BEST, COLUMN-WIDTH, boxes)

          (* Put a line at the end to space out the paragraph. We
             should do this with glue. *)
          val lines = list-rcons
            (lines, box {(Box) height = PARAGRAPH-VSPACE-BOTTOM} [])

          do VERBOSE andthen
            let in
              print "----packed lines---\n";
              list-app (fn (lay : layout) =>
                        let in
                          print "==\n";
                          debug-print-doc lay;
                        end) lines;
              print "-------------------\n"
            end

          (* Now can treat the contents of lines as stickers.
             The line itself remains a box. *)
          val lines : layout list = list-map stick-horizontally lines

          do VERBOSE andthen
            let in
              print "----now as lines---\n";
              list-app (fn (lay : layout) =>
                        let in
                          print "==\n";
                          debug-print-doc lay;
                        end) lines;
              print "-------------------\n"
            end

          (* Maybe advance to the next column (or page) to place
             something. *)
          fun get-placement height =
            if !current-ypos +. height <=. BODY-HEIGHT
            then
              (* Place here at no cost. *)
              ()
            else
              if !column-empty
              then
              (* If we're already at the top of the column, then
                 we don't have any choice but to place it. *)
                let
                  val overrun-height = BODY-HEIGHT -. (!current-ypos +. height)
                in
                  (* TODO: We assume it's the full column width. But really
                     we should be measuring the actual width of the line
                     that's overflowing. *)
                  emit-badness (COLUMN-WIDTH *. overrun-height)
                end
              else
                (* New column. *)
                let in
                  emit-column ();
                  current-column := !current-column + 1;
                  current-ypos := 0.0;
                  !current-column >= COLUMNS
                  andthen fail "Need to implement pages!";
                  (* badness from unfilled column? *)
                  ()
                end

          fun addline (line : layout) : unit =
            case layoutcase line of
              Node (BOX, {(Box) height } as attrs, children) =>
                let in
                  get-placement height;
                  add-column-sticker
                  (sticker (attrs without (Box)width
                            without (Box)height
                            with comment = "line"
                            with x = 0.0
                            with y = !current-ypos) (layout-concat children));
                  current-ypos := !current-ypos +. height
                end
            | _ => fail "only expecting boxes with known height in addline"

        in
          list-app addline lines
        end

      val paras : layout list = get-paragraphs (lay :: nil)
    in
      list-app insert-paragraph paras;
      emit-column ()
    end

  (* This creates a rigid box. We could improve it in various ways:
     - Don't be fixed width!
     - It would be better as a text property anyway, so that it
     can flow across columns and pages.
     But I want to test layout of rigid stuff like this.
     *)
  fun blockquote lay =
    let
      val LEFT-INDENT = inch 0.25
      val WIDTH = inch 3.25
      val lay = it lay
      val boxes = get-boxes lay
      val lines : layout list = pack-boxes (BEST, WIDTH, boxes)
      val lines : layout list = list-map stick-horizontally lines
    in
      stick-vertically
      (LEFT-INDENT,
       box {(Box) width = WIDTH} (layout-concat lines))
    end

  fun title lay =
    let
      (* probably we want center justification *)
      val WIDTH = inch 3.75
      val lay = span {(Span) font-bold = true, font-size = point 36.0 } lay
      val boxes = get-boxes lay

      val lines : layout list = pack-boxes (BEST, WIDTH, boxes)
      val lines : layout list = list-map stick-horizontally lines

      val t =
      stick-vertically
      (0.0, box {(Box) width = WIDTH} (layout-concat lines))
    in
      (* debug-print-doc t; *)
      t
    end

  fun vspace vdim =
    let val doc =
      (* Break before (0 size) and after (with given height). *)
       [[box {(Box) height = 0.0, width = 0.0,
              glue-break-penalty = -9999999.0 } [ ]]
        [box {(Box) height = vdim, width = 0.0,
              glue-break-penalty = -9999999.0 } [ ]]]
    in
      debug-print-doc doc;
      doc
    end

in

  (main-text
  (palatino
   [
    [title[My test]][vspace (inch 0.1)]
    Dr. Tom Murphy VII, Ph.D.

    The system goes on-line March 13th, 2024.

    magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut

of coverage. For a particular product received by a particular user,

    [helvetica
     [
      Does it make sense to put paragraphs...

      ... inside a span?

      I guess so?
      ]]

    This is my paper. I have written some filler text in order to get the
    main layout loop working, [helvetica[which]] is the design thing that's
    stressing
    me out. Makes sense, as it's kind of the [b[core]] of everything.

    [rephrase
     [This paragraph has some [b[markup]] in it. It's also inside
      a call to rephrase.]]

    [cite murphy2013first]

    Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.

    A "User Product" is either (1) a "consumer product", which means any tangible personal property which is normally used for personal, family, or household purposes, or (2) anything designed or sold for incorporation into a dwelling. In determining whether a product is a consumer product, doubtful cases shall be resolved in favor of coverage. For a particular product received by a particular user, "normally used" refers to a typical or common use of that class of product, regardless of the status of the particular user or of the way in which the particular user actually uses, or expects or is expected to use, the product. A product is a consumer product regardless of whether the product has substantial commercial, industrial or non-consumer uses, unless such uses represent the only significant mode of use of the product.

If during a game it is found that an illegal move, including failing to meet the
requirements of the promotion of a pawn or capturing the opponent's king, has
been completed, the position immediately before the irregularity shall be
reinstated. If the position immediately before the irregularity cannot be determined
the game shall continue from the last identifiable position prior to the irregularity.
The clocks shall be adjusted according to Article 6.13. The Articles 4.3 and 4.6 apply
to the move replacing the illegal move. The game shall then continue from this reinstated position.

After the action taken under Article 7.4.a, for the first two illegal moves by a player
the arbiter shall give two minutes extra time to his opponent in each instance; for a
third illegal move by the same player, the arbiter shall declare the game lost by this
player. However, the game is drawn if the position is such that the opponent cannot
checkmate the player's king by any possible series of legal moves.

I understand the risks and wish to continue.

[* single quotes *]
[blockquote["It would threaten millions of small businesses operating on a razor-thin margin because they're unable to find enough workers," said Cassidy, the ranking Republican on the committee. "Now they've got the same workers, but only for three-quarters of the time. And they have to hire more."]]

[* fancy quotes *]
[blockquote[“It would threaten millions of small businesses operating on a razor-thin margin because they’re unable to find enough workers," said Cassidy, the ranking Republican on the committee. "Now they’ve got the same workers, but only for three-quarters of the time. And they have to hire more.”]]

    And now it is over.

    [bibliography()]

   ]))

end
