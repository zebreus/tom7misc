(* Layout stuff.

   This is a core BoVeX library, which wraps the low-level
   primitives (the 'layout' type, boxes-and-glue algorithm,
   dimensions, etc.) to offer a higher-level layout interface.
   It's used by multiple document types and styles.

   Conventions:

   - Scores are given as penalties (positive is bad).
   - Dimensions are in points, nominally 1/72 of an inch.
   - Coordinates start at 0.0 at the top left, with y positive meaning
     down, and x positive meaning right. (Note this is vertically
     flipped from what pdf.h and the internal PDF format do!)

*)

do REQUIRE-STDLIB

datatype provide-layout = REQUIRE-LAYOUT

(* XXX Temporary? *)
import "font.bovex"
import "image.bovex"
import "layout-base.bovex"

val LAYOUT-VERBOSE = false

(* For debugging, emit glyphs in some otherwise invisible places. *)
val SHOW-CODES = false

(* For expand-contract, in places where we don't want to do any
   expansion or contraction (e.g. kerning points). *)
val EPSILON-COEFFICIENT = 0.0000000005

(* Types of layout:
   (It would be nice if we were distinguishing these statically!)

   (A) Doc. What the document contains in [...]. This is the
   type called "layout" in BoVeX.
   This is mainly a tree of styled text, but it can also include
   fixed-size boxes whose positioning has been finalized (this
   ties the loop with the below).
   We use <span> to set properties for the subtree, and <box>
   for existing fixed-size boxes.

   rephrase can work on this kind of text. It might see some
   kinds of styling, but the nested boxes are treated opaquely.
   It returns the same type.

   This is generally what the author of the document is thinking about.

   (B) AllBox. Here we apply the text properties to the <span>
   so that each word (or kerning particle) has its metrics.

   We can process the document all at once to produce the AllBox
   version.

   (C) Rendered. Here we have figured out the final placement of
   everything.
   *)


(* Record that something bad happened. This is used for global
   optimization. Badness is nominally measured in square points
   that look bad. For example, if text overflows its container,
   then this is the area of the bounding box of the part of the
   text rectangle that's outside its container. Of course this
   can be scaled as desired.
   *)
(* emit-badness : float -> unit *)

fun image-sticker { img = img as (Image img-handle),
                    x : float, y : float, width : float } =
  let
    (* Compute height from image native dimensions. *)
    val ratio : float = image-aspect-ratio img
    val height = width /. ratio
  in
    sticker {(Sticker) x = x, y = y,
             img = img-handle, img-width = width, img-height = height} []
  end

fun apply-font font lay =
  span {(Span) font-face = (font-family font)} lay

fun fill-rectangle { x, y, width, height, fill-color } : layout =
  sticker {(Sticker) x = x, y = y, rect-width = width, rect-height = height,
           fill-color = fill-color } []

fun rectangle { x, y, width, height, stroke-color, line-width } : layout =
  sticker {(Sticker) x = x, y = y, rect-width = width, rect-height = height,
           line-width = line-width,
           stroke-color = stroke-color } []

fun line { x0, y0, x1, y1, stroke-color, line-width } : layout =
  sticker {(Sticker) x = x0, y = y0, line-x1 = x1, line-y1 = y1,
           stroke-color = stroke-color, line-width = line-width} []

fun helvetica layout = apply-font HELVETICA layout
fun times-roman layout = apply-font TIMES layout
fun courier layout = apply-font COURIER layout
fun zapf-dingbats layout = apply-font ZAPF-DINGBATS layout
fun fixedersys layout = apply-font FIXEDERSYS layout

fun b layout =
  span {(Span) font-bold = true} layout

fun it layout =
  span {(Span) font-italic = true} layout

fun color rgba layout =
  span {(Span) font-color = rgba } layout

fun size pts layout =
  span {(Span) font-size = pts } layout

fun sup pts layout = span {(Box) font-size = pts *. 0.75,
                           dy = -0.25 *. pts } layout

fun sticker-translate (dx, dy) layout =
  case get-attrs layout of
    {(Node) display = "box"} =>
      fail "Can't apply sticker-translate to a box."
  | {(Node) display = "span"} =>
      fail "Can't apply sticker-translate to a span."
  | _ => sticker {(Sticker) x = dx, y = dy} layout

val tt = courier

fun rm layout =
  span {(Span) font-bold = false, font-italic = false} layout

fun break () =
  box {(Box) height = 0.0, width = 0.0,
       glue-ideal = 0.0,
       glue-expand = 1000000.0,
       glue-contract = EPSILON-COEFFICIENT,
       glue-break-penalty = -9999999.0 } (if SHOW-CODES
                                          then [|]
                                          else [ ])

fun break-ok () =
  box {(Box) height = 0.0, width = 0.0,
       glue-break-penalty = 1.0 } [ ]

fun hfill () =
  box {(Box) height = 0.0, width = 0.0,
       glue-ideal = 0.0,
       (* happily take up more space, but don't become negative *)
       glue-expand = 1000000.0,
       glue-contract = EPSILON-COEFFICIENT,
       glue-break-penalty = 0.0 } (if SHOW-CODES
                                   then [-]
                                   else [ ])

(* Unbreakable horizontal space *)
fun rigid-hspace dim =
  box {(Box) height = 0.0, width = 0.0,
       glue-ideal = dim,
       glue-contract = 1000000.0,
       glue-expand = 1000000.0,
       glue-break-penalty = 9999999.0 } []

fun vspace vdim =
  (* Break before (0 size) and after (with given height). *)
  [[break ()]
   [box {(Box) height = vdim, width = 0.0,
         glue-break-penalty = -9999999.0 }
    (if SHOW-CODES
     then [v] else [ ])]]

(* Generates a series of lines (boxes) with the glue turned into definite
   padding. Still in "AllBox" format. Returns the badness and the list of
   lines. *)
fun pack-boxes-horiz (algo : packing-algorithm, just : justification,
                      width : float, content : layout) : (float * layout list) =
  let
    val (badness, lines) = pack-boxes (algo, just, width, content)

    fun set-height (line : layout) =
      case layoutcase line of
        Node (BOX, attrs, boxes) =>
          let
            fun max-height (h, nil) = h
              | max-height (h, box :: rest) =
              case layoutcase box of
                Node (BOX, {(Box) height}, _) =>
                  max-height (float-max(height, h), rest)
              | _ => max-height (h, rest)

            val height = max-height (0.0, boxes)
          in
            (* Could also strip height from words here! *)
            box (attrs with (Box)height = height) (layout-concat boxes)
          end
      | _ => fail "Bug: Expected pack-boxes to return a series of lines (boxes)"

  in
    (badness, list-map set-height lines)
  end

(* Pack boxes (e.g. paragraphs) vertically into columns. *)
fun pack-boxes-vert (height : float, content : layout) : (float * layout list) =
  let
    (* XXX we probably want left-justified here. *)
    val (badness, columns) = pack-boxes (BEST, FULLY-JUSTIFIED, height, content)
  in
    (badness, columns)
  end

(*
 Parsing text into paragraphs (and perhaps other stuff).
 We parse a series (list) of siblings. When it's a box,
 we copy it verbatim. We treat groups transparently (and
 I think these are now normalized away?). We accumulate
 text and spans until we see a paragraph break (two
 newlines) or something else we're interested in. Spans
 can be nested within paragraphs, and this is natural.
 If we have a paragraph inside a span, we smear the span's
 attributes onto the paragraph pieces, and join the
 first one and last one to surrounding paragraphs. *)

(* A "float", which is placed out-of-order with the body text,
   but (at least nominally) "after" the point it appears in
   the text. *)
datatype float-pos = FloatBottom | FloatTop | FloatInline
datatype parafloat = ParaFloat of { pos : float-pos list, box : layout }

(* Each item is some body text, then the accumulated space after that
   paragraph, and any floats that shall be placed (eventually) after it. *)
datatype paragraph-item =
  ParagraphItem of { body : layout, space-after: float, floats: parafloat list }

fun get-paragraphs (ls : layout list) : paragraph-item list =
  let
    do LAYOUT-VERBOSE
      andthen
      let in
        print "----get paras----\n";
        list-app (fn l =>
                  let in
                    debug-print-doc l;
                    print "\n==\n";
                  end) ls;
        print "-----------------\n";
      end

    (* XXX This should depend on the font *)
    val PARAGRAPH-VSPACE-BOTTOM = 12.0
    val LINE-VSPACE-BOTTOM = 1.0

    val rev-paragraphs : paragraph-item list ref = ref nil

    (* Current paragraph being accumulated. *)
    val acc : layout ref = ref []
    fun append (lay : layout) = acc := [[!acc][lay]]
    val acc-floats : parafloat list ref = ref nil
    fun append-floats (fs : parafloat list) =
      acc-floats := (!acc-floats @ fs)

    fun next-paragraph () =
      let in
        (if layout-empty (!acc)
         then ()
         else rev-paragraphs := ParagraphItem { body = !acc,
                                                space-after = 0.0,
                                                floats = !acc-floats } ::
           !rev-paragraphs);
        acc := [];
        acc-floats := nil
      end

    (* Add a break to the previous paragraph, but don't keep accumulating
       them if we already had a break. *)
    fun add-break amount =
      (* Or make this optional? *)
      if amount !=. 0.0
      then
        case !rev-paragraphs of
          ParagraphItem { body, space-after, floats } :: t =>
            rev-paragraphs :=
            ParagraphItem { body = body,
                            space-after = float-max (space-after, amount),
                            floats = floats } :: t
        | nil => rev-paragraphs :=
            ParagraphItem { body = [],
                            space-after = amount,
                            floats = nil } :: nil
      else ()

    (* Normalize whitespace. This can probably be improved.
       We drop leading space from paragraphs (they are usually
       indented), for one thing. *)
    fun normalize s =
      normalize-whitespace s

    fun normalize (true, s) =
      string-strip-prefix " " (normalize-whitespace s)
      | normalize (false, s) =
      normalize-whitespace s


    datatype break-type = BREAK-PARA | BREAK-LINE
    fun chop-to-break big : (break-type * string * string) option =
      let
        (* Both two newlines and two backslashes are two characters. *)
        val SIZE = 2
        fun found (pos, what) =
          let
            val a = substr (big, 0, pos)
            val b = substr-rest (big, pos + SIZE)
          in
            SOME(what, a, b)
          end
      in
        case (string-find (big, "\n\n"),
              string-find (big, "\\\\")) of
          (NONE, NONE) => NONE
        | (SOME pos, NONE) => found (pos, BREAK-PARA)
        | (NONE, SOME pos) => found (pos, BREAK-LINE)
        | (SOME p1, SOME p2) =>
            if p1 < p2
            then found (p1, BREAK-PARA)
            else found (p2, BREAK-LINE)
      end

    fun do-one-text (after-p, s) =
      let
        do LAYOUT-VERBOSE andthen print ("one text [" ^ s ^ "]")
      in
      case chop-to-break s of
        (* Tail of input. *)
        NONE => append (layout (normalize (after-p, s)))
      | SOME (break-type, para, rest) =>
          (* Got a paragraph, either ending with a paragraph
             break or line break. *)
          let in
            append (layout (normalize (after-p, para)));
            next-paragraph ();
            add-break
            (case break-type of
               BREAK-PARA => PARAGRAPH-VSPACE-BOTTOM
             | BREAK-LINE => LINE-VSPACE-BOTTOM);
            do-one-text (true, rest)
          end
      end

    (* Process one of the layouts in the input list. *)
    fun do-one lay =
      case layoutcase lay of
        Text s => do-one-text (false, s)
      | Node (BOX, _, _) => append lay
      | Node (SPAN, attrs, children) =>
          let
            val paras : paragraph-item list = get-paragraphs children
            (* Apply the same attributes to every paragraph. Floats
               are not modified, however. *)
            fun apply-attrs (ParagraphItem {body, space-after, floats}) =
              ParagraphItem { body = span attrs body,
                              space-after = space-after,
                              floats = floats }

            val spans = list-map apply-attrs paras

            (* The head of the nested paragraph is really part of the parent
               paragraph. Append its contents to the current one. *)
            fun append-to-current (ParagraphItem { body, space-after, floats }) =
              let in
                append body;
                append-floats floats;
                space-after
              end

          in
            (* We are nested inside a paragraph already, so nested
               "paragraphs" are not necessarily actual paragraphs; they
               may need to be merged with the parent. *)
            case spans of
              nil => append (span attrs [])
            | pp :: pps =>
                let
                  (* Here we are passing along space to be applied
                     at the bottom of this paragraph. It is always
                     ended immediately, but this better matches the
                     accumulation functions we have available. *)
                  fun rec (space : float,
                           ParagraphItem { body, space-after, floats } :: ps) =
                    let in
                      next-paragraph ();
                      add-break space;
                      append body;
                      rec (space-after, ps)
                    end
                    | rec (space : float, nil) =
                    if space !=. 0.0
                    then
                      let in
                        (* If we have space at the end of a nested
                           paragraph, it's a proper paragraph rather
                           than something that can be continued in
                           the parent. *)
                        next-paragraph();
                        add-break space
                      end
                    else ()

                  (* First paragraph continues the current. *)
                  val space = append-to-current pp
                in
                  (* now each one starts a new paragraph. but note
                     that we don't flush the final one unless it
                     ends with space. *)
                  rec (space, pps)
                end
          end
      | Node (GROUP, attrs, children) =>
          if obj-empty attrs
          then list-app do-one children
          else
            let in
              debug-print-doc lay;
              fail "this code doesn't preserve attrs on a group"
            end
      | Node (STICKER, _, _) =>
            fail ("not expecting to see stickers when getting " ^
                  "paragraphs. You should put them inside a box.")

  in
    list-app do-one ls;
    next-paragraph ();
    list-rev (!rev-paragraphs)
  end

(* Makes the contents of a box into stickers.
   Returns a box whose width is the sum of the actual widths of
   these stickers. *)
fun stick-horizontally (lay : layout) : layout =
  case layoutcase lay of
    Node (BOX, attrs, children) =>
      let
        val width = ref 0.0
        fun rec (x, nil) =
          let in
            (* print ("Final width: " ^ int-to-string (round x) ^ "\n"); *)
            width := x;
            nil
          end
          | rec (x, h :: t) =
          case layoutcase h of
            Node (BOX, attrs as {(Box) width}, ch) =>
              let
                val (dx, dy) = attrs-pos attrs
                val s =
                  sticker (attrs
                           without (Box)width
                           without (Box)height
                           without (Box)dx
                           without (Box)dy
                           with (Sticker)x = x +. dx
                           with (Sticker)y = dy) (layout-concat ch)
              in
                s :: rec (x +. width, t)
              end
          | _ => fail "Expected line's contents to be boxes."

        (* Run first for effect of setting width *)
        val ch = layout-concat (rec (0.0, children))
      in
        box (attrs with (Box)width = !width) ch
      end
  | _ => fail "Expected line to be a box!"

(* Like stick-horizontally, but vertically. *)
fun stick-vertically (x : float, lay : layout) : layout =
  let
    fun do-lines attrs children =
      let
        val height = ref 0.0
        fun rec (y, nil) =
          let in
            height := y;
            nil
          end
          | rec (y, h :: t) =
          case layoutcase h of
            Node (BOX, attrs as {(Box) height}, ch) =>
              let
                val (dx, dy) = attrs-pos attrs
                val s =
                  sticker (attrs
                           without (Box)width
                           without (Box)height
                           without (Box)dx
                           without (Box)dy
                           with (Sticker)x = x +. dx
                           with (Sticker)y = y +. dy) (layout-concat ch)
              in
                s :: rec (y +. height, t)
              end
          | _ => fail "In stick-vertically, expected contents to be boxes."

        val ch = rec (0.0, children)
      in
        box (attrs with (Box)height = !height) (layout-concat ch)
      end
  in
    case layoutcase lay of
      Node (BOX, attrs, children) => do-lines attrs children
    | Node (GROUP, _, children) => do-lines {(Object)} children
    | _ =>
      let in
        debug-print-doc lay;
        fail "Expected line to be a box!"
      end
  end

(* Place properly kerned text, but with no wrapping. *)
fun text-sticker { x, y } lay =
  let
    val lay = layout-map-text normalize-whitespace lay
    val boxes = get-boxes lay

    (* Turn the line into a sticker, ignoring its width/height *)
    fun stick-line (line : layout) : layout =
      case layoutcase line of
        Node (BOX, attrs, children) =>
          sticker (attrs without (Box)width
                   without (Box)height
                   with x = 0.0
                   with y = 0.0) (layout-concat children)
      | _ => fail "expected box containing the line's stickers"

  in
    (* Hack: "infinite" line width. *)
    case pack-boxes-horiz (BEST, LEFT-JUSTIFIED, 9999999999.0, boxes) of
      (badness-ignored, line :: nil) =>
        let
          val s = stick-line (stick-horizontally line)
        in
          (* debug-print-doc s; *)
          sticker {(Sticker) x = x, y = y } s
        end
    | (_, nil) =>
        (* Empty title ok. *)
        []
    | _ => fail ("Expected just one line when packing boxes on " ^
                 "an 'infinite' line.")
  end

fun centered-text-sticker { x, y, width } lay =
  let
    val lay = layout-map-text normalize-whitespace lay
    val boxes = get-boxes lay

    (* Turn the line into a sticker, ignoring its width/height *)
    fun stick-line (line : layout) : layout =
      case layoutcase line of
        Node (BOX, attrs, children) =>
          sticker (attrs without (Box)width
                   without (Box)height
                   with x = 0.0
                   with y = 0.0) (layout-concat children)
      | _ => fail "expected box containing the line's stickers"

  in
    case pack-boxes-horiz (BEST, CENTERED, width, boxes) of
      (badness-ignored, lines) =>
        let
          val lines = layout-concat (list-map stick-horizontally lines)

          (* do debug-print-doc lines *)
        in
          sticker {(Sticker) x = x, y = y }
          (stick-line (stick-vertically (0.0, lines)))
        end
  end

fun box-stick-at {x : float, y : float} lay =
  case layoutcase lay of
    Node (BOX, attrs, children) =>
      sticker (attrs with x = x with y = y) (layout-concat children)
    | _ => fail "Expected box argument to box-stick-at"

(* Image on its own line, maintaining aspect ratio. *)
fun image { img = img as (Image img-handle), width } =
  let
    (* Compute height from image native dimensions. *)
    val ratio : float = image-aspect-ratio img
    val height = width /. ratio

  in
    (* Break before (0 size) and after (with given height). *)
    [[break ()]
     [box {(Box) height = height, width = width,
           img = img-handle, img-width = width, img-height = height,
           glue-break-penalty = -9999999.0 } [ ]]]
  end

(* Here we give the height, since the typical usage is to make it flow
   with some text. Allows breaks. *)
fun image-inline { img = img as (Image img-handle), height, dy } = let
    (* Compute width from image native dimensions. *)
    val ratio : float = image-aspect-ratio img
    val width = height *. ratio

    (* Would it be cleaner to put the image sticker inside the box? *)
    val doc =
      box {(Box) height = height, width = width, dy = dy,
           img = img-handle, img-width = width, img-height = height,
           glue-break-penalty = 0.0, glue-ideal = 0.0 } []
  in
    doc
  end


(* This creates a rigid box. We could improve it in various ways:
   - Don't be fixed width!
   - It would be better as a text property anyway, so that it
   can flow across columns and pages.
   But I want to test layout of rigid stuff like this.
   *)
fun blockquote lay =
  let
    val LEFT-INDENT = inch 0.25
    val WIDTH = inch 3.25
    val lay = it (layout-map-text normalize-whitespace lay)
    val boxes = get-boxes lay
    val (badness, lines : layout list) =
      pack-boxes-horiz (BEST, FULLY-JUSTIFIED, WIDTH, boxes)
    do emit-badness badness
    val lines : layout list = list-map stick-horizontally lines
  in
    stick-vertically
    (LEFT-INDENT,
     box {(Box) width = WIDTH} (layout-concat lines))
  end

(* Justify even the final line of the paragraph. *)
fun justify-all lay = span {(Span) justification = "all" } lay
(* Justify all but the final line. *)
fun justify-full lay = span {(Span) justification = "full" } lay
fun justify-left lay = span {(Span) justification = "left" } lay

fun monospace-block-ext { left-indent, width,
                          line-spacing,
                          font-size,
                          attrs : obj } lay =
  let
    (* Since we generate boxes directly, we need the actual
       font name, not the family. *)
    val ff = font-regular FIXEDERSYS

    fun flat-text lay =
      case layoutcase lay of
        Text str => str
      | Node (GROUP, _, ch) =>
          string-list-concat (list-map flat-text ch)
      | _ => fail "Markup is not supported inside monospace-lines."

    val lines =
      let val sl : string list = string-split "\n" (flat-text lay)
      in
        list-map (fn (s : string) =>
                  (box (obj-merge
                        ({(Box)
                          width = width,
                          font-name = ff,
                          font-size = font-size,
                          height = font-size +. line-spacing},
                         attrs))
                   (layout s))) sl
      end
  in
    stick-vertically
    (left-indent,
     box {(Box) width = width} (layout-concat lines))
  end

fun get-box lay =
  let
    val lay = layout-map-text normalize-whitespace lay
    val boxes = get-boxes lay
  in
    (* Hack: "infinite" line width. *)
    case pack-boxes-horiz (BEST, LEFT-JUSTIFIED, 9999999999.0, boxes) of
      (badness-ignored, line :: nil) => stick-horizontally line
    | (_, nil) => box {(Box) width = 0.0, height = 0.0} []
    | _ => fail ("Expected just one line when packing boxes on " ^
                 "an 'infinite' line.")
  end

val DEFAULT-MONOSPACE-BLOCK-LEFT-INDENT = inch 0.05
fun monospace-block lay =
  monospace-block-ext { left-indent = DEFAULT-MONOSPACE-BLOCK-LEFT-INDENT,
                        width = inch 3.4,
                        line-spacing = 0.05,
                        font-size = 12.0,
                        attrs = {(Object) } } lay

(* TODO: Rationalize global config like this. *)
val SECTION-FONT-SIZE = ref (point 15.0)

fun section lay =
  span {(Span) font-bold = true, font-size = !SECTION-FONT-SIZE }
  [[lay][hfill()][break()]]

val SUBSECTION-FONT-SIZE = ref (point 13.5)

fun subsection lay =
  span {(Span) font-bold = true, font-size = !SUBSECTION-FONT-SIZE }
  [[lay][hfill()][break()]]

val SUBSUBSECTION-FONT-SIZE = ref (point 12.0)

fun subsubsection lay =
  span {(Span) font-bold = true, font-size = !SUBSUBSECTION-FONT-SIZE }
  [[lay][hfill()][break()]]

fun paragraph lay =
  span {(Span) font-bold = true} [[lay].] ^^
  box {(Box) width=3.0, glue-ideal=3.0, glue-expand = 1.5 } []

(* TODO: Hanging indent. *)
(* TODO: intra-bullet spacing. We need for them to not just be
   interpreted as paragraphs in order for that to work, but then
   they will not flow across columns. I think the right thing to
   do is add more metadata to flowing text (margins, etc.) so
   that the paragraph layout logic can handle it. *)
fun ul laylist =
  hfill() ^^ break() ^^
  layout-concat
  (list-map (fn lay =>
             span {(Span) font-bold = true} [•] ^^
             box {(Box) width=2.0, glue-ideal=2.0,
                  glue-expand = 0.25, glue-contract = 0.75 } [] ^^
             lay ^^ [\\])
   laylist)


(* Rephrasing is enabled deep in the paragraph layout code, since
   it needs to understand how variants affect badness. Documents
   can globally disable/enable these *)

(* If SOME, the number of rephrasing attempts to use for every
   eligible paragraph by default. *)
val REPHRASE-ALL : int option ref = ref NONE
val NO-REPHRASE : bool ref = ref false

object Rephrase of { rephrase-times : int }

(* Explicitly disable rephrasing for the paragraph. *)
fun no-rephrase lay = span {(Span) no-rephrase = true } lay
(* Explicitly ask for N attempts at rephrasing the paragraph. *)
fun rephrase-paragraph (times : int) (p : layout) : layout =
  let val r = span {(Rephrase) rephrase-times = times} p
  in
    (* debug-print-doc r; *)
    r
  end

(* Pack a paragraph into lines. This is basically pack-boxes o get-boxes,
   but we also look for rephrase contexts. If there are any, we
   try multiple rephrasings and pick the one with the best badness.

   Emits the badness from the best packing as a side effect.

   TODO: Specify the "column" width with a function, allowing for
   non-rectangular packing (e.g. lettrines). *)
fun pack-one-paragraph (column-width : float) (para : layout) : layout list =
  let
    val VERBOSE = false

    fun rephrasings (times, para) : (float * layout) list =
      let
        object InternalRephrasings of { loss : float }
        fun get-metadata one =
          case get-attrs-opt one of
            SOME {(InternalRephrasings) loss } => (loss, one)
          | _ => fail ("internal-rephrasings should annotate the returned " ^
                       "layout with the (semantic) loss")
      in
        list-map get-metadata (unjoin (internal-rephrasings (times, para)))
      end

    (* XXX I should fix whatever's creating singleton groups, but
       it prevents us from recognizing the top-level rephrase
       paragraph. So peel any of those off. *)
    fun unjoin-if-one l =
      case unjoin l of
        one :: nil => one
      | _ => l

    val para = unjoin-if-one para

    do VERBOSE andthen
      let in
        print "----insert para----\n";
        debug-print-doc para;
        print "-------------------\n"
      end

    fun consume-outer-span (f : obj -> justification option) s :
      (justification option * layout) =
      case layoutcase s of
        Node (SPAN, attrs, children) =>
          let
            (* If there's a single child, recurse. *)
            val (ropt, rchildren) =
              case children of
                one :: nil => consume-outer-span f one
              | _ => (NONE, layout-concat children)
          in
            (* if f matches the span, always remove it.
               but we let inner spans override the outer ones. *)
            case (f attrs, ropt) of
              (NONE, _) => (ropt, span attrs rchildren)
            | (SOME vouter, inner as SOME _) => (inner, rchildren)
            | (outer, NONE) => (outer, rchildren)
          end
      | _ => (NONE, s)

    (* TODO: Like its name says, this consumes the span. But that
       could cause it to drop other attributes that are on the
       same span. Rethink how we do this (but this whole
       part is a mess, obviously.) *)
    val (just : justification option, para : layout) =
      consume-outer-span
      (fn {(Span) justification } =>
       SOME (case justification of
               "full" => FULLY-JUSTIFIED
             | "left" => LEFT-JUSTIFIED
             | "all" => ALL-JUSTIFIED
             | "center" => CENTERED
             | s => (fail ("Unsupported justification type " ^ s)) :
                 justification) : justification option
      | _ => NONE : justification option)
      para

    val just : justification = option-get FULLY-JUSTIFIED just

    (* TODO: Allow rephrasing mid-paragraph. Same idea of passing
       the rewrap function to represent the "hole"; it's just
       fiddly. Probably would be good to provide context to the
       LLM, as well.

       XXX this or consume-outer-span is dropping attributes
       *)
    fun extract-rephrasing rewrap para =
      case layoutcase para of
        Node (SPAN, attrs as {(Rephrase) rephrase-times }, ch) =>
          if !NO-REPHRASE
          then (0.0, rewrap para) :: nil
          else list-map (fn (loss, para) => (loss, rewrap para))
               (rephrasings (rephrase-times, para))
      | Node (SPAN, attrs, child :: nil) =>
          extract-rephrasing (fn x => rewrap (span attrs x)) child
      | Node (BOX, _, _) => (0.0, rewrap para) :: nil
      | Node (STICKER, _, _) => (0.0, rewrap para) :: nil
      | _ =>
          (case (!REPHRASE-ALL, !NO-REPHRASE) of
             (SOME n-times, false) =>
               list-map (fn (loss, para) => (loss, rewrap para))
               (rephrasings (n-times, para))
             | _ => (0.0, rewrap para) :: nil)

    val paras : (float * layout) list = extract-rephrasing (fn x => x) para

    (* TODO: Right now we just take the lowest overall badness (per line),
       ignoring the semantic loss (Epsom's version). We could
       blend them somehow. *)
    fun compute-penalty { badness : float, semantic-loss : float,
                          lines : int,
                          text } =
      let in
        (*
        print ("Badness " ^ int-to-string (round badness) ^
               " loss " ^ int-to-string (round (loss *. 100.0)) ^
               "% lines " ^ int-to-string lines ^ "\n");
        *)
        (* debug-print-doc text; *)
        badness /. int-to-float lines
      end

    fun get-best (NONE, nil) = fail "bug: no options?"
      | get-best (SOME (badness, best), nil) =
      let in
        emit-badness badness;
        best
      end
      | get-best (best, (loss, para) :: t) =
      let
        val boxes = get-boxes para
        val (badness : float, lines : layout list) =
          pack-boxes-horiz (BEST, just, column-width, boxes)

        val score = compute-penalty { badness = badness,
                                      semantic-loss = loss,
                                      lines = list-length lines,
                                      text = para }

        fun new-best NONE = SOME (score, lines)
          | new-best (best as (SOME (best-score, best-lines))) =
          if score <. best-score
          then SOME (score, lines)
          else best
      in
        get-best (new-best best, t)
      end
  in
    get-best (NONE, paras)
  end

(*
  TODO: xrefs allow us to refer to a string that is not known at the time
  the document is evaluated.
*)

(* Given all the paragraphs in the document, pack them and
   turn them into stickers and emit them.

   TODO: It would be better if this placed them within
   rigid column-shaped boxes with stickers, rather than
   emitting them.
*)
(* XXX should probably just use pack-boxes for this, but
   they are vertical boxes. *)
(* XXX pass a "metrics" object or something *)
datatype paragraph = Paragraph of { (* boxes with stickers inside *)
                                    lines : layout list }
fun pack-paragraphs (LEFT-MARGIN, TOP-MARGIN, GUTTER,
                     BODY-HEIGHT,
                     COLUMN-WIDTH, COLUMNS,
                     paras : paragraph list) =
  let
    val COLUMN-STRIDE = COLUMN-WIDTH +. GUTTER
    val LEFT-COLUMN-X = LEFT-MARGIN

    val current-page = ref 0

    (* Layout state. *)
    val current-column = ref 0
    (* y position within column. *)
    val current-ypos = ref 0.0
    val column-empty = ref true

    val column-stickers-rev : layout list ref = ref nil
    fun add-column-sticker s =
      let in
        column-empty := false;
        column-stickers-rev := s :: !column-stickers-rev
      end


    (* Emits the current column (if non-empty); clears it. *)
    fun emit-column () =
      let
        val colx =
          LEFT-COLUMN-X +.
          ((int-to-float (!current-column)) *. COLUMN-STRIDE)
      in
        !column-empty otherwise
        output (!current-page,
                sticker ({(Sticker)
                          x = colx ,
                          y = TOP-MARGIN }
                         with column-num = !current-column
                         with comment = "column"
                         with column-stride = COLUMN-STRIDE
                         with left-margin = LEFT-MARGIN)
                (layout-concat (list-rev (!column-stickers-rev))));
        column-stickers-rev := nil;
        column-empty := true
      end

    (* Maybe advance to the next column (or page) to place
       something. *)
    fun get-placement height =
      if !current-ypos +. height <=. BODY-HEIGHT
      then
        (* Place here at no cost. *)
        ()
      else
        if !column-empty
        then
        (* If we're already at the top of the column, then
           we don't have any choice but to place it. *)
          let
            val overrun-height = BODY-HEIGHT -. (!current-ypos +. height)
          in
            (* TODO: We assume it's the full column width. But really
               we should be measuring the actual width of the line
               that's overflowing. *)
            emit-badness (COLUMN-WIDTH *. overrun-height)
          end
        else
          (* New column. *)
          let in
            emit-column ();
            current-column := !current-column + 1;
            current-ypos := 0.0;
            !current-column >= COLUMNS
            andthen
            let in
              current-column := 0;
              current-page := !current-page + 1;
            end;
            (* badness from unfilled column? *)
            ()
          end

    fun addline (line : layout) : unit =
      case layoutcase line of
        Node (BOX, {(Box) height } as attrs, children) =>
          let in
            get-placement height;
            add-column-sticker
            (sticker (attrs without (Box)width
                      without (Box)height
                      with comment = "line"
                      with x = 0.0
                      with y = !current-ypos) (layout-concat children));
            current-ypos := !current-ypos +. height
          end
      | _ => fail "only expecting boxes with known height in addline"

    fun addpara (Paragraph { lines }) =
      list-app addline lines

  in
    list-app addpara paras;
    emit-column ()
  end


(* This returns multiple paragraphs because processing a paragraph
   may emit floaters. *)
fun process-paragraph (COLUMN-WIDTH : float,
                       p : layout) : paragraph list =
  let
    val VERBOSE = false
    val lines = pack-one-paragraph COLUMN-WIDTH p

    do VERBOSE andthen
      let in
        print "----packed lines---\n";
        list-app (fn (lay : layout) =>
                  let in
                    print "==\n";
                    debug-print-doc lay;
                  end) lines;
        print "-------------------\n"
      end

    (* Now can treat the contents of lines as stickers.
       The line itself remains a box. *)
    val lines : layout list = list-map stick-horizontally lines

    do VERBOSE andthen
      let in
        print "----now as lines---\n";
        list-app (fn (lay : layout) =>
                  let in
                    print "==\n";
                    debug-print-doc lay;
                  end) lines;
        print "-------------------\n"
      end
  in
    (Paragraph { lines = lines }) :: nil
  end

(* Below here should move to twocolumn or article or whatever. *)
fun title lay =
  span {(Span)
        justification = "left",
        font-bold = true,
        font-size = point 30.0 } [[lay][hfill()][break()]]

fun sub-title lay =
  span {(Span)
        justification = "left",
        font-bold = true,
        font-size = point 22.0 } [[lay][hfill()][break()]]

fun author lay = span {(Span) justification = "left" }
                       [[lay][hfill()][break()]]
fun date lay = [[lay][hfill()][vspace 16.0]]

(* TODO: Some kind of page config object that specifies the
   various constant dimensions, with defaults. *)

(* Generally just one of these, for the toplevel document.
   This breaks the layout into paragraphs, and then inserts
   them one by one into columns.

   TODO: First process make a pass over the document's layout looking
   for sequentially-numbered stuff like sections and bib-sources.
   Assign them numbers imperatively in some global map. A second pass
   can replace them with their actual numbers (or whatever).
   *)
fun main-text lay =
  let
    val VERBOSE = LAYOUT-VERBOSE orelse false

    (* TODO: Make configurable, obviously *)
    val PAGE-WIDTH = inch 8.5
    val PAGE-HEIGHT = inch 11.0
    val LEFT-MARGIN = inch 0.4
    val TOP-MARGIN = inch 0.5
    val GUTTER = inch 0.3
    val COLUMNS = 2
    do COLUMNS >= 1 otherwise fail "There must be at least one column!"
    val RIGHT-MARGIN = inch 0.4
    val BOTTOM-MARGIN = inch 0.5

    val BODY-WIDTH = PAGE-WIDTH -. (LEFT-MARGIN +. RIGHT-MARGIN)
    val BODY-HEIGHT = PAGE-HEIGHT -. (TOP-MARGIN +. BOTTOM-MARGIN)
    val COLUMN-WIDTH =
      (BODY-WIDTH -. (int-to-float (COLUMNS - 1) *. GUTTER))
      /. (int-to-float COLUMNS)

    (* XXX don't discard floats! *)
    fun process (ParagraphItem { body, space-after, floats }) =
      let in
        process-paragraph (COLUMN-WIDTH, body) @
        (if space-after !=. 0.0
         then Paragraph { lines =
                          (box {(Box) height = space-after,
                                width = COLUMN-WIDTH} []) :: nil } :: nil
         else nil)
      end

    (* Parse layout to find paragraph breaks. This handles whitespace
       and figures out how much space comes after each paragraph.
       Normalize spans that contain paragraphs onto the constituent
       paragraphs.
       It also accumulates "floats," which are not yet rendered.
       XXX: Render floats! *)
    val para-items : paragraph-item list = get-paragraphs (lay :: nil)

    (* Blank space that can hold text, like a "column." Used as part of
       the layout process here, as we allocate new pages and place floats.

       TODO: A better thing here would be a polygon that we rasterize
       when we turn it into line lengths. But rectangles are already
       pretty expressive because we can just link them. I think if this
       is a full polygon, it's probably better to have a general purpose
       trapezoid-packing boxes-and-glue algorithm, so I'm saving that for
       future work! *)
    datatype space =
      SpaceRect of { page: int, x: float, y: float, w: float, h: float }

    (* I think the way this should work now is:

       para-items is the full document content that we process.

       Two work (source) queues: the text queue and the float queue.

       One sink queue: the "space," which is the blank space allocated
       in the document. This is a list of rectangles (position,
       dimensions) that are implicitly linked (by the order in the
       queue) as the document's reading order.

       The loop looks like this:

       - If the text queue is empty, get a paragraph item and convert it
       to text, using the current space to tell us the line widths
       that are available.
          - if the space is insufficient, allocate an additional page
            and do this again. (Note that this could result in bad
            performance if there are very long paragraphs; a future
            version could do binary search or just emit partial
            paragraphs!)
          - if there are no pages but there are still floats, allocate
            pages until the floats are all satisfied (and then we are done).

       - Now the text queue has packed lines in it. (Why didn't we just
         place them in the previous stage?). I guess we want to be
         somewhat lazy about the vertical packing so that we aren't
         just placing lines greedily into the space.

       allocate-page:
          - We call this when we have insufficient space. Use the
            document configuration to add a page and produce the
            rectangles on it. If the float queue has anything in
            it, deposit those on the page, which results in
            different page rectangles.

       There's a circular dependency here that we need to break.
       Finding optimal line breaks for a paragraph requires knowing
       the space's width (and we then commit to that length for the
       paragraph's broken lines). But placing paragraphs optimally
       into the space also requires changing where we vertically
       place lines. This could affect the width of the space
       because of non-rectangular columns, or when text spans columns
       of different width.

       A full solution would optimize both line breaking and vertical
       layout simultaneously, although this adds complexity and comes
       with other downsides (e.g. increasing the dimensionality of
       the boxes-and-glue memo table). So the compromise here is:

        - We work a paragraph at a time (as described above), perhaps
          with some limit on paragraph length.
        - We first commit to the "space" (when creating a new blank
          page, depositing floats)
        - We break lines assuming that the paragraph will go in the
          next available space.
        - We then deposit paragraphs into the space, but pack using
          boxes-and-glue vertically (at the line level). We assign
          badness when a line does not fit in the actual space. We
          know that there is at least one good fit (the first fit)
          since we optimized breaks assuming that one. But in the
          extremely common case that the columns are rectangular
          (or indeed that the entire document has a single width)
          then we will have significant freedom to break to reduce
          paragraph-level badness (e.g. orphans). In the case that
          the space has an exotic shape, we will mostly be
          constrained to the first placement because the broken
          lines will already be the wrong length to fit elsewhere.

          *)

      (* XXX IN PROGRESS *)
    fun place-paragraphs (para-items : paragraph-item list) =
      let

        (* Get a vector of line widths using the currently
           available space, or return NONE if there does not
           seem to be enough space. This is heuristic, using
           a greedy fit. The goal is to see how much space
           we probably need in order to do the proper layout. *)
        fun get-widths (body, nil) = NONE
          | get-widths (body,
                        SpaceRect { page = _, x = _, y = _, w, h } :: rest) =
          fail "unimplemented"


        (* Break the body paragraph into lines (rigid boxes), given
           the space. If there is insufficient space, allocate a
           new page, possibly placing floats, and try again.
           PERF: For very long paragraphs, we may have to take many
           passes; consider breaking them up.

           Returns the new { lines, floats, space }. Imperatively
           allocates pages and permanently places floats on them. *)
        fun break-for-space (body : layout, space-after : float,
                             floats, space) =
          let
            (* This logic should be improved to pass non-uniform
               widths to pack-boxes. Right now it insists that all
               space is the same width. *)
          in
            fail "unimplemented"
          end

        fun step { lines = nil, paras = nil, floats = nil, space = _ } =
          (* All queues are exhausted, so we have no more content
             to place. Done. *)
          nil
          | step { lines = nil,
                   paras = ParagraphItem { body, space-after,
                                           floats = new-floats } :: prest,
                   floats, space } =
          let
          (* No more lines in the queue, but there're still more
             paragraphs to place. *)

            val { lines, floats, space } =
              break-for-space (body, space-after, floats, space)

          in
            step { lines = lines,
                   paras = prest,
                   floats = floats @ new-floats,
                   space = space }
          end

      in

        fail "unimplemented"
      end

    (* Do rephrasing if needed.
       Optimize line breaks for each paragraph.
       Turn each paragraph into a series of vertical boxes (lines, which
       are stickers). *)
    val paras : paragraph list = list-concat (list-map process para-items)
  in
    pack-paragraphs (LEFT-MARGIN, TOP-MARGIN, GUTTER,
                     BODY-HEIGHT,
                     COLUMN-WIDTH, COLUMNS, paras)
  end
