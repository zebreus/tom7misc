let
  import "stdlib.bovex"
  import "chess.bovex"
  import "layout.bovex"

  (* chess.h "DebugMoveString" format *)
  fun parsepos (file, rank) =
    let
      val x = file - 0'a'
      val y = 7 - (rank - 0'1')
    in
      (x < 0 orelse x >= 8) andthen fail "bad file";
      (y < 0 orelse y >= 8) andthen fail "bad rank";
      pos (x, y)
    end

  fun parsepromo nil = NONE
    | parsepromo (0'=' :: 0'Q' :: nil) = SOME QUEEN
    | parsepromo (0'=' :: 0'N' :: nil) = SOME KNIGHT
    | parsepromo (0'=' :: 0'B' :: nil) = SOME BISHOP
    | parsepromo (0'=' :: 0'R' :: nil) = SOME ROOK
    | parsepromo _ = fail "bad promo string"

  fun parsemove s =
    case string-explode s of
      file1 :: rank1 :: 0'-' :: 0'>' :: file2 :: rank2 :: promo =>
        Move { src = parsepos (file1, rank1),
               dst = parsepos (file2, rank2),
               promote = parsepromo promo }
    | _ => fail ("unexpected move format: [" ^ s ^ "]")


  fun board-parses s =
    let in
      print ("parse [" ^ s ^ "]\n");
      case board-from-fen s of
        ILLEGAL msg => fail ("Can't parse fen [" ^ s ^ "]: " ^ msg)
      | OK board => board
    end

  fun board-fails s =
    case board-from-fen s of
      ILLEGAL msg => ()
    | OK board => fail "FEN unexpectedly parses: [" ^ s ^ "]"

  (* some test boards *)
  do board-parses
    "rnbqkbnr/p1ppppp1/1P5p/8/8/8/PP1PPPPP/RNBQKBNR b KQkq - 0 3"
  do board-parses
    "rnbqkbnr/p2ppp2/1p5p/8/6pP/5NP1/PP1PPP2/RNBQKB1R b KQkq h3 0 6"
  do board-parses
    "rnbqkbnr/p2ppp2/7p/8/1p5P/5pPB/PP1PPP2/RNBQK2R b Qkq - 1 9"
  do board-parses
    "r2k1bnr/p2ppp2/b1n2N1p/q7/7P/1P3pPB/1P1PPP2/R1BQK2R w Q - 5 14"
  do board-parses
    "r2k1bnr/p3pp2/b2p1N1p/q3n3/1P5P/1P4PB/1B1PQP2/2KR3R b - - 1 20"

  do board-fails
    (* Can't castle *)
    "r2k1bnr/p3pp2/b2p1N1p/q3n3/1P5P/1P4PB/1B1PQP2/2KR3R b Q - 1 20"

  do board-fails
    (* Row is too long *)
    "8/8/7k/8/K8/8/8/8 w - - 1 20"

  do board-fails
    (* Invalid turn color *)
    "8/8/7k/8/K7/8/8/8 g - - 1 20"

