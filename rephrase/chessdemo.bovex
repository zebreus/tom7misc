  e7->d7 e7->e8 e7->e6 e7->e5 e7->e4 e7->d8 e7->f8 e7->d6 e7->c5 e7->b4 e7->a3 e7->f6 f7->d8 f7->h8 f7->d6 f7->e5 f7->h6 f7->g5 h7->h8=N h7->h8=B h7->h8=R h7->h8=Q a6->c7 a6->b8 a6->c5 a6->b4 e3->e4 a2->b3 a2->c4 a2->d5 a2->e6 a2->b1 b2->b4 b2->a3 b2->b3 b2->c3 c2->b3 c2->b1 c2->c3 c2->d1 c1->b1 c1->a1 c1->d1 c1->e1 c1->f1 c1->g1 c1->h1]

  val testdata = testdata-regression ^ "\n" ^ testdata2
  val testcases =
    let
      fun parse-moves ms =
        list-map parsemove (string-tokens (fn 0' ' => true | _ => false) ms)

      fun parsecases (fen :: moves :: rest) =
        (fen, board-parses fen,
         set-from-list move-compare (parse-moves moves)) ::
        parsecases rest
        | parsecases nil = nil
        | parsecases (f :: nil) =
        let in
          print ("wrong number of lines? [" ^ f ^ "]\n");
          nil
        end

      val lines = string-fields (fn 0x0A => true | _ => false) testdata
    in
      parsecases lines
    end

  val all-promos = NONE :: SOME ROOK :: SOME KNIGHT :: SOME BISHOP ::
    SOME QUEEN :: nil

  fun one-testcase (fen,
                    board as Board { squares, turn,
                                     castling = _, en-passant = _},
                    expected) =
    let
      do print (fen ^ "\n")
      val actual = ref (set-empty move-compare)

      (* try every possible move *)
      do
        (* Only try to move my own pieces, to save time *)
        map-appi
        (fn (src, (src-color, src-piece)) =>
         color-eq (src-color, turn) andthen
         let
           (* do print ("Moves from " ^ pos-to-string src ^ "...\n") *)
           val piece-promos =
             case src-piece of
               PAWN => all-promos
             | _ => NONE :: nil
         in
           for 0 63
           (fn dst =>
            let
              val promos =
                case unpos dst of
                  (_, 0) => piece-promos
                | (_, 7) => piece-promos
                | _ => NONE :: nil
            in
              list-app
              (fn promo =>
               let
                 val move = Move { src = src, dst = dst, promote = promo }
               in
                 case make-move (board, move) of
                   OK board => actual := set-insert (!actual, move)
                 | ILLEGAL msg => () (* print ("ILLEGAL: " ^ msg ^ "\n") *)
               end) promos
            end)
         end)
        squares

      val elist = set-to-list expected
      val alist = set-to-list (!actual)
    in
      if list-eq move-eq (elist, alist)
      then ()
      else
        let
          fun printmoves nil = print "\n"
            | printmoves (m :: rest) =
            let in
              print (" " ^ move-to-string m);
              printmoves rest
            end

          fun diff (m1 :: r1, m2 :: r2) =
            (case move-compare (m1, m2) of
               EQUAL => diff (r1, r2)
             | LESS =>
                 let in
                   print ("Missing: " ^ move-to-string m1 ^ "\n");
                   diff (r1, m2 :: r2)
                 end
             | GREATER =>
                 let in
                   print ("Incorrect: " ^ move-to-string m2 ^ "\n");
                   diff (m1 :: r1, r2)
                 end)
            | diff (nil, nil) = ()
            | diff (nil, r2) =
               let in
                 print "All incorrect: ";
                  printmoves r2;
                end
            | diff (r1, nil) =
                let in
                  print "All missing: ";
                  printmoves r1;
                end

        in
          print ("Board: " ^ fen ^ "\n");
          print "Expected: ";
          printmoves elist;
          print "Actual: ";
          printmoves alist;
          diff (elist, alist);
          fail "move lists differ"
        end
    end

  do list-app one-testcase testcases

in
  print "OK\n"
end

