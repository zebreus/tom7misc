  let
    val W = (NONE, WORDLE-EMPTY)
    fun X s = (SOME s, WORDLE-GREY)
    fun N s = (SOME s, WORDLE-GREEN)
    fun Y s = (SOME s, WORDLE-YELLOW)
    val board =
      (X "W" :: X "R" :: X "O" :: X "N" :: X "G" :: nil) ::
      (X "R" :: X "U" :: X "L" :: Y "E" :: Y "S" :: nil) ::
      (X "T" :: X "I" :: Y "M" :: Y "E" :: Y "S" :: nil) ::
      (Y "S" :: X "H" :: X "A" :: Y "M" :: Y "E" :: nil) ::
      (W :: W :: W :: W :: W :: nil) ::
      nil

    val QUOTE-MARGIN = inch 14.0
    val QUOTE-FUDGE = inch 1.0
  in
    combo-slide slide
    (StickerElt (wordle-board { x = inch 18.0, y = inch 4.8,
                                cell-size = inch 3.2,
                                board = board }) ::
