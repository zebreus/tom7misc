                 with TITLE-FONT-SIZE = 160.0
                 with TOP-MARGIN = inch 4.0
                 with CONTENT-START-Y = inch 5.5)
  [Boxes and glue]
  (image-load "../algorithm-dark.png");

  let
    val YPOS = inch 1.8
  in
    combo-slide slide
    (TextBox { x = DEFAULT-LEFT-MARGIN,
               y = YPOS +. 128.0,
               width = inch 18.5,
               text = (span {(Span) line-spacing = 8.0}
                       [Here is an example of applying the boxes
                        and glue algorithm to this very text. Most
                        of the break points lead to extremely long
                        or short lines, so only a small region
                        is of any interest. But those details
                        within the region matter.]) } ::
     Image { img = image-load "../boxes-and-glue-matrix.png",
             x = pixel 1800.0,
             y = YPOS -. 72.0,
             scale = INTSCALE 2 } ::
     nil)
  end;

  diagram-slide (slide
                 with TITLE-FONT-SIZE = 160.0
                 with TOP-MARGIN = inch 4.0
                 with LEFT-MARGIN = DEFAULT-LEFT-MARGIN -. inch 1.5
                 with CONTENT-START-Y = inch 5.5)
  [Boxes and LLMers Glue]
  (image-load "../algorithm2-dark.png");

  just-video (slide with LOOP-VIDEO = true) "comparison.mp4";

  placeholder-slide [features.mp4];

  set-output-section (!current-page, "features");

  let
    type particle = { x: float, y : float, lay : layout,
                      width: float, height : float,
                      dx : float, dy : float }

    fun letterbox (s : layout) =
      let val box = get-box s
      in
        case layoutcase box of
          Node (BOX, attrs as {(Box) width, height}, ch) =>
            { width = width, height = height, lay = box }
        | _ => fail "getbox should return one box"
      end

    val SYSTEMX = SLIDE-WIDTH *. 0.5
    val SYSTEMY = SLIDE-HEIGHT *. 0.333
    val SYSTEMW = SLIDE-HEIGHT *. 0.444
    val SYSTEMH = SYSTEMW

    val sim : particle list ref = ref nil
    (* Add some particles *)
    fun add () =
      let val { width, height, lay } =
        let val c = (random64() andb 0xFFFFFFFF) orb 0x303030AA
        in
          letterbox (color c (b (size 128.0 (apply-font FRANKLIN [e]))))
        end
      in
        sim := { x = random () *. SYSTEMW,
                 y = random () *. SYSTEMH,
                 dx = (random() *. 20.0) -. 20.0,
                 dy = (random() *. 20.0) -. 20.0,
                 width = width,
                 height = height,
                 lay = lay } :: !sim
      end

    do for 0 100 (fn _ => add ())


    fun simulate () =
      let

        (*
        val BOTTOM = 1000.0
        val RIGHT = SLIDE-WIDTH -. 80.0
        val LEFT = 40.0
        *)

        val BOTTOM = SYSTEMH
        val LEFT = 0.0
        val RIGHT = SYSTEMW

        fun sim-one { x, y, dx, dy, width, height, lay } =
          let
            val x = x +. dx
            val y = y +. dy
            val dy = dy +. 8.0

            val (y, dy) =
              if y +. height >. BOTTOM
              then (BOTTOM -. height, 0.0 -. dy *. 0.90)
              else (y, dy)
            val (x, dx) =
              if x +. width >. RIGHT
              then (RIGHT -. width, 0.0 -. dx *. 0.90)
              else (x, dx)
            val (x, dx) =
              if x <. LEFT
              then (LEFT, 0.0 -. dx *. 0.90)
              else (x, dx)
          in
            { x = x, y = y, dx = dx, dy = dy,
              width = width, height = height,
              lay = lay }
          end
      in
        sim := list-map sim-one (!sim)
      end

    fun theslide t =
      let
        do simulate ()

        val texts =
          list-map
          (fn ({ x = x, y = y, dx = dx, dy = dy,
                 width = width, height = height,
                 lay = lay } : particle) =>
           TextBox { x = x +. SYSTEMX, y = y +. SYSTEMY,
                     width = inch 38.0,
                     text = lay })
          (!sim)
      in
        combo-slide slide
        (Title [Additional features] ::
         Bullets
         ([Bibliography database] ::
          (three-d { font-name = font-regular PALATINO,
                     font-size = 144.0 *. (t +. 1.0),
                     width = 80.0, height = 144.0, text = "3D text" }) ::
          [Achievements] ::
          nil) ::
         TextBox { x = SYSTEMX, y = SYSTEMY +. SYSTEMH +. 96.0,
                   width = inch 38.0,
                   text = (palatino [Particle systems]) } ::
         texts)
      end

    val NUM-FRAMES = (* 64 *) 4

    val start-page = !current-page
    fun makeframe n =
      let
        val t = n / (NUM-FRAMES - 1)
        (* Ease in/out *)
        (* val pos = t *. t *. t -. 3.0 *. (t *. t) +. 2.0 *. t *)
        val pos = 0.5 *. (1.0 -. cos(t *. 3.141592653589))
        do print ("Frame " ^ int-to-string n ^ "/" ^
                  int-to-string NUM-FRAMES ^ " \n")
      in
        (* generating a slide advances the frame, so keep going back. *)
        current-page := start-page;
        current-frame := n;
        theslide t
      end
  in
    for 0 (NUM-FRAMES - 1) makeframe;
    current-frame := 0;
  end;

  just-image-2x "achievement-mp4.png";
  (* placeholder-slide [achievement.mp4]; *)

  (* Using BoVeX / license *)

  let
    val cboard =
      sticker-translate (inch 4.0, inch 8.0)
      (chessboard
       { size = inch 16.0,
         fen = "rnbqk2r/pp2bppp/5n2/3p2B1/3Q4/2N1PN2/PP3PPP/R3KB1R " ^
         "b KQkq - 0 8" })
  in

    combo-slide slide
    (Title [Additional features] ::
     StickerElt cboard ::
     nil)

  end;

  (* TODO: Download. Licenses *)

  let
  in
    combo-slide slide
    (Title [Future work] ::
     Bullets
     ([Automatically respond to reviewer comments] ::
      [Automatically respond to viewer comments] ::
      [Tool use] ::
      nil) ::
     nil)
  end;

  let
    (* 8 was ok *)
    val MARGIN = inch 13.1
    fun paperclip-slide text =
      combo-slide slide
      (Title [Future work] ::
       TextBox { x = MARGIN,
                 y = 2160.0 *. 0.5 -. inch 3.0,
                 width = 3840.0 -. (MARGIN *. 2.0),
                 text = (justify-full text) } ::
       nil)
  in
     paperclip-slide
     [For example, it can be quite challenging to typeset a large
      number like in the sentence “The universe contains
      approximately 1,000,000,000 paperclips.”];

     paperclip-slide
     [For example, it can be quite challenging to typeset a large
      number like in the sentence “The universe contains
      exactly
      100,000,000,000,000,000,000,000
      paperclips.”];
  end;

  (* So, we did it! *)

  morphism-slide "morphism6.png";
  morphism-slide "morphism7.png";

  let
    val tom = image-load "../tom7-portrait-glasses.png"
    val { width, height = _ } = image-size tom
    val LEFT-MARGIN = inch 4.0
    val EXTRA-RIGHT-MARGIN = inch 6.0
  in
    combo-slide (slide with BULLET-FONT-SIZE = 96.0
                 with BULLET-LINE-GAP = 48.0)
    (Image { x = SLIDE-WIDTH -. 2.0 *. int-to-float width,
             y = 0.0,
             scale = INTSCALE 2,
             img = tom } ::
     TextBox { x = inch 4.0,
               y = inch 3.0,
               width = SLIDE-WIDTH -. int-to-float width -.
               (LEFT-MARGIN *. 2.0) -. EXTRA-RIGHT-MARGIN,
               text =
               justify-full
               [In this talk—and [it[with]] this talk—I presented
                [BoVeX], a new computer typesetting system that finally
                solves the AI alignment problem. It follows
                in the tradition of Knuth’s [TeX], but with modern
                amenities such as requiring over 128 gigabytes of RAM.] } ::

     TextBox { x = inch 4.0,
               (* XXX hax *)
               y = inch 22.0,
               width = SLIDE-WIDTH -. int-to-float width -.
               (LEFT-MARGIN *. 2.0) -. EXTRA-RIGHT-MARGIN,
               text =
               justify-full
               [With it, [color 0xFFFFAAFF [Tom 7]] can finally be
                spared all of his typographic irritant‘s.[hfill()]
                [color 0x9999FFFF [#blessed #subscribe]]] } ::
     nil)
  end;

  (* But it's not just typography. Another thing I hate ... *)
  placeholder-slide [crimescene.mp4];

end
