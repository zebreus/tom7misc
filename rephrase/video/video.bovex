  (* do REPHRASE-ALL := SOME 50 *)
  do REPHRASE-ALL := NONE
  do NO-REPHRASE := true

  fun bullet-at t lay = (t, Bullet ({(Bullet) }, lay))

  fun zigzag zig lay =
    case layoutcase (get-box lay) of
      Node (BOX, attrs as {(Box) width, height}, ch) =>
        let
          val y-offset = height *. -0.15
          val d =
            box attrs
            (layout-concat
             (ch @
              (if zig then
                  (image-sticker
                   { img = image-load-cache "../red-underline.png",
                     x = 0.0, y = y-offset, width = width } :: nil)
               else nil)
              ))
        in
          d
        end
    | _ =>
        let in
          debug-print-doc lay;
          fail "Expected box with width/height from get-box"
        end

  fun placeholder-slide s =
    combo-slide slide
    (TextBox { x = inch 2.0,
               y = 2160.0 *. 0.5,
               width = 3840.0 -. inch 4.0,
               text = (size 128.0 (color 0xFFCCCCFF s)) } ::
    nil)

  val DEJAVU : font-family =
    font-load-family { name = "dejavu",
                       regular = SOME "DejaVuSans.ttf",
                       (* These do exist, but I do not need them. *)
                       bold = NONE,
                       italic = NONE,
                       bold-italic = NONE }

  (* https://www.gnu.org/software/freefont/ *)
  val FREESERIF : font-family =
    font-load-family { name = "freeserif",
                       regular = SOME "freeserif.ttf",
                       (* These do exist, but I do not need them. *)
                       bold = NONE,
                       italic = NONE,
                       bold-italic = NONE }

  fun dejavu layout = apply-font DEJAVU layout
  fun chessfont layout = apply-font FREESERIF layout

  fun chessboard { size = board-size, fen } =
    let
      val squares =
        case board-from-fen fen of
          ILLEGAL msg => fail ("Can't parse fen [" ^ fen ^ "]: " ^ msg)
        | OK Board { squares, castling = _, en-passant = _, turn = _ } =>
            squares

      val square-size = board-size /. 8.0

      fun square (xx, yy) =
        let
          val c =
            case (xx + yy) mod 2 of
              0 => 0xffffddff
            | _ => 0x86a666ff
        in
          fill-rectangle { x = square-size *. int-to-float xx,
                           y = square-size *. int-to-float yy,
                           width = square-size,
                           height = square-size,
                           fill-color = c }
        end

      fun draw-pieces () =
        map-foldl nil (fn (pos, (c, p), b : layout list) =>
                       let
                         val (x, y) = unpos pos
                         (* XXX center? *)
                         val xo = square-size *. 0.10
                         (* text is measured from baseline, so go almost
                            a whole square down *)
                         val yo = square-size *. 0.85

                         (* tweak to your preferences *)
                         val font-size = square-size *. 1.25

                         fun gen cc u =
                           text-sticker
                           { x = xo +. square-size *. int-to-float x,
                             y = yo +. square-size *. int-to-float y }
                           (chessfont (color cc (size font-size u)))

                         val ub = layout (piece-unicode (BLACK, p))
                         val uf = layout (piece-unicode (WHITE, p))

                         val (ccb, ccf) =
                           case c of
                             WHITE => (0xFFFFFFFF, 0x333333FF)
                           | BLACK => (0x333333FF, 0x000000FF)
                       in
                         gen ccb ub :: gen ccf uf :: b
                       end) squares
    in
      (* First, draw board as squares. *)
      layout-concat (list-tabulate-2d (8, 8, square)) ^^
      layout-concat (draw-pieces ())
    end

  fun morphism-slide filename =
    let
      val img = image-load filename
      val { width, height } = image-size img
      val LR-MARGIN = inch 1.0
      val MORPHISM-X = LR-MARGIN
      val MORPHISM-Y = inch 4.50
      val m-slide =
        (slide
         with TITLE-FONT-SIZE = point 180.0
         with TOP-MARGIN = inch 4.0
         with CONTENT-START-Y = inch 5.5)
    in
      combo-slide m-slide
      (Title [The Hurry-Coward So-So-Morphism] ::
       Image { img = img,
               x = MORPHISM-X, y = MORPHISM-Y,
               scale = WIDTH (SLIDE-WIDTH -. 2.0 *. LR-MARGIN) } ::
       nil)
    end

in

