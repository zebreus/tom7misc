let

datatype layout-list = Cons of string | Nil

datatype display = BOX | SPAN

datatype layoutcase =
  (* Includes empty nodes. *)
  Node of display * layout-list

fun layoutcase (l : layout) =
  Node (BOX, Nil)

in
  case layoutcase [] of
    Node (BOX, boxes) =>
      let
        fun max-height Nil = 0.0
          | max-height _ =
          let in
            layoutcase [];
            0.0
          end

        val _ = max-height boxes
      in
        Nil
      end

end
