(*   -*- electric-indent-local-mode: nil -*- *)
let
  import "stdlib.bovex"
  import "layout.bovex"
  import "cite.bovex"
  import "paper.bib"

  import "aeoud-shared.bovex"

  (* do REPHRASE-ALL := SOME 50 *)
  do REPHRASE-ALL := NONE
  do NO-REPHRASE := true

in

  (* TODO: Better bullet graphic. Can embed fonts, remember *)

  title-slide slide (size (point 280.0) (color 0xFFFFFFFF [Badness 0]))
  [by Tom 7]
  [An Evening Of... 2024];

  title-slide slide (size (point 380.0) (color 0xFF0000FF [UN-]))
  (color 0xFF7777FF [necessary])
  [detail?!!‽];


  (* TODO It has come to my attention... *)

 (* Oh my god, it burns my eyes!! And not just because it's so
    bright... the glaring mistake... *)
  (* People will look at this and think, "Looks fine to me!" *)
  just-image "typography0.png";
  just-image "typography1.png";
  just-image "typography2.png";
  just-image "typography3.png";
  just-image "typography4.png";
  just-image "typography5.png";
  just-image "typography6.png";

  just-video slide "bottle.mp4";

  (* couple more gags here? *)
  (* Rules of Wordle expert mode are just wrong.

     Parker Square
     error correction?

     *)

  (* Lorem Epsom *)

  let
    val YPOS = inch 4.0

    fun lorem-slide zig =
    combo-slide slide
    (Title [Corporate Preso] ::
     TextBox { x = DEFAULT-LEFT-MARGIN,
               y = YPOS,
               width = inch 9.0,
               text = [[zigzag zig (default-text [Lorem Epsom])]
                       dolor sit amet,
                       [color 0xFFFFFFEE
                        [consectetur adipiscing elit,]]
                       [color 0xFFFFFFCC
                        [sed do eiusmod tempor
                         incididunt ut labore]]
                       [color 0xFFFFFFAA
                        [et dolore magna aliqua. Ut]]
                       [color 0xFFFFFF88
                        [enim ad minim veniam, quis nostrud]]
                       [color 0xFFFFFF55
                        [exercitation ullamco laboris nisi ut]]
                       [color 0xFFFFFF33
                        [aliquip ex ea commodo consequat. Duis]]
                       [*
                       aute irure dolor in reprehenderit in
                       voluptate velit esse cillum dolore eu
                       fugiat nulla pariatur. Excepteur sint
                       occaecat cupidatat non proident, sunt
                       in culpa qui officia deserunt mollit
                       anim id est laborum *]] } ::
     Image { img = image-load "graph.png",
             x = pixel 900.0,
             y = YPOS,
             width = SOME (pixel 900.0) } ::
     nil)
  in
    lorem-slide false;
    lorem-slide true;
  end;

  combo-slide (slide with GAP = 0.0)
  (Image { img = image-load "lorem-portrait.png",
           x = pixel 1100.0,
           y = pixel 100.0,
           width = NONE } ::
   Title [The Villain: Lorem Epsom] ::
   Bullets ([Probably never even read the Wikipedia article
             on [it[Lorem Ipsum]]] ::
            (* [Leverages synergy] :: *)
            [If you tell him there's a mistake in the
             math he takes this as a personal attack] ::
            [Loves the phrases "[em[metaverse]]" and
             "[em[blockchain]]" and
             "[em[generative AI]]" but doesn't know why] ::
            [Is successful and rich] ::
            nil) ::
   nil);

  (* Epsom vs Knuth

    * Thinks of spreadsheets as "the one without clip-art"

    *)

  combo-slide slide
  (Image { img = image-load "knuth-portrait-trace.png",
           x = pixel 1100.0,
           y = pixel 80.0,
           width = NONE } ::
   Title [The Hero: Donald Knuth] ::
   Bullets ([[em[Wrote]] the article on [it[Lorem Ipsum]]] ::
            [Will pay you if you find an error] ::
            [Took 35 years to write a book] :: nil) ::
   nil);

  combo-slide slide
  (Title [The Art of Computer Procrastination] ::
   Bullets ([1975: 3000 pages of hand-written text] ::
            [1977: Publisher proofs don't look that good ] ::
            [1982: Returns with TeX ] ::
            [XXX finish the slide ] ::
            [Took 35 years to write a book] :: nil) ::
   Image { img = image-load "knuth-portrait-trace.png",
           x = pixel 1100.0,
           y = pixel 80.0,
           width = NONE } ::
   nil);

  (* XXX need a better transition here.
     since it's a timeline, we could just get up to 2023?
     *)


  combo-slide slide
  (Bullets ([Wow OMG I'm sick of hearing about it] ::
            [Torment Nexus] ::
            [It does kinda work though] :: nil) ::
   Image { img = image-load "torment-nexus.png",
           x = pixel (1920.0 -. 1080.0),
           y = pixel 0.0,
           width = NONE } ::
   Title [Nightmare on LLM Street] ::
   nil);

  (* Clarissa explains it all *)
  (* I'm Tom 7. I specialize in cursed computer software.
     I don't do it for the likes. I do it because I'm
     riddled with anxiety and I find it therapeutic to
     digest vexing things by systematizing them. *)

  let
    val morphism = image-load "morphism.png"
    val { width, height } = image-size morphism
    val MORPHISM-X = (SLIDE-WIDTH -. (int-to-float width)) *. 0.5
    val MORPHISM-Y = inch 2.75
  in
    (* There is also "space" in typography::metroid *)
    combo-slide (slide with TITLE-FONT-SIZE = point 90.0
                 with TOP-MARGIN = inch 2.0
                 with CONTENT-START-Y = inch 2.75)
    (Title [The Hurry-Coward So-So-Morphism] ::
     Image { img = morphism,
             x = MORPHISM-X, y = MORPHISM-Y,
             width = NONE } ::
     nil);

    (* But first, we need to talk about Super Metroid. *)
    (* Let's just add one more character to this play: Super Metroid *)
    combo-slide (slide with TITLE-FONT-SIZE = point 90.0
                 with TOP-MARGIN = inch 2.0
                 with CONTENT-START-Y = inch 2.75)
    (Title [The Hurry-Coward So-So-Morphism] ::
     Image { img = image-load "morphism2.png",
             x = MORPHISM-X, y = MORPHISM-Y,
             width = NONE } ::
     nil);

    combo-slide (slide with TITLE-FONT-SIZE = point 90.0
                 with TOP-MARGIN = inch 2.0
                 with CONTENT-START-Y = inch 2.75)
    (Title [The Hurry-Coward So-So-Morphism] ::
     Image { img = image-load "triforce.png",
             x = MORPHISM-X +. inch 1.5, y = MORPHISM-Y -. inch 5.0,
             width = SOME 1300.0 } ::
     Image { img = image-load "morphism2.png",
             x = MORPHISM-X, y = MORPHISM-Y,
             width = NONE } ::
     nil);
  end;

  monospace-slide (slide with TITLE-FONT-SIZE = point 88.5
                   with MONOSPACE-FONT-SIZE = point 40.0
                   with TOP-MARGIN = inch 2.0
                   with CONTENT-START-Y = inch 3.2)
  [Super Metroid Speed Guide and FAQ]
[  Once you save the game at your ship (about 1 hour 15 minutes is good), go
down to Tourian. Do not save your game in Tourian if you have intentions of
returning to any previously explored section on Planet Zebes. There will be
a few Metroids to kill before you reach Mother Brain, and they must all die
in order to continue to Mother Brain. Read the boss guide for more details.
Once Mother Brain is defeated, you will need to hurry back to your ship. By
now you will already have the HYPER BEAM. From Mother Brain’s room, go west
and then south. Take the blue door at the bottom and speed dash east. Super
jump up, and continue north. Once you land up top and are running east, aim
diagonally down to the right and shoot an unseen door. Eventually, you will
get to this door since lava will start to rise from the floor in this area.
Speed dash through the door you preopened, and charge for a super jump. Hug
either the left or right wall in the Craterian shaft and super jump up. Now
quickly get to your ship before the planet explodes. There should be almost
a minute left on the timer. Sit back and watch the ending! Did you beat the
game within 1 hour and 20 minutes?

(c) 1996 rs1n
https://gamefaqs.gamespot.com/snes/588741-super-metroid/faqs/10114];

  let
    val mother = image-load "motherbrain.png"
    val { width = mother-width, height = _ } = image-size mother
    val YPOS = inch 4.0

    (* right aligned *)
    val motherbrain-x = pixel (1920.0 -. int-to-float mother-width)
    val GAP = inch 0.25
  in
    combo-slide (slide with TITLE-FONT-SIZE = point 88.5)
    (TextBox { x = DEFAULT-LEFT-MARGIN,
               y = YPOS,
               width = motherbrain-x -. GAP -. DEFAULT-LEFT-MARGIN,
               text =
               [The first level of Super Metroid Speed Guide and FAQ is
                easy with lexical coinduction and time travel] } ::
     Image { img = mother,
             x = motherbrain-x,
             y = pixel 0.0,
             width = NONE } ::
     Title [Automating speedrunner chores] ::
     nil)
  end;

  quote-slide slide [¿Cómo se LLama?]
  [Exercise in rephrasing text. The following paragraph
   needs to be rephrased so that it retains its precise meaning, but
   with minor variations in the specific choice of words, punctuation,
   and so on. No new facts should be introduced or removed, but it is
   good to use synonyms and change the word order and phrasing.

   Original paragraph:];

  monospace-slide (slide
                   with MONOSPACE-FONT-SIZE = 50.0)
  [Original paragraph]
  (* This is the text from demo.txt *)
  [Here's a demo of it generating monospaced text. I'm just
sampling text a line at a time, and if the line happens
to be exactly the right length, then I keep that line
and continue. If not, then I reset to the beginning of
the line and roll the dice again.];

  (* XXX show schematic of prompt, paragraph, output *)

  for 0 45 (fn i => just-image ("monospace-slides/frame" ^
                                int-to-string i ^ ".png"));

  (* XXX better video! *)
  just-video slide "monospace30.mp4";

  just-image "monospace-finished.png";

  quote-slide (slide with BACKGROUND = "metroidbg.png"
               with BODY-FONT-COLOR = 0xFFFF77FF) []
  [Great !! You fulfiled your mission. It will revive peace
   in space. But,it may be invaded by the other Metroid. Pray for a true
   peace in space!];

  bullet-slide slide [Baby mode]
  ([300 lines of code] ::
   [It only took an afternoon] ::
   [You have to look at [tt[monospace text]]] :: nil);

  bullet-slide slide [Knuth Any% Speedrun]
  ([Make a new programmable document preparation system] ::
   [Full-featured typed programming language] ::
   [Kerning, hyphenation, and all that crap] ::
   [New fonts, and software for making fonts] ::
   [AI-enhanced text layout algorithm] ::
   [Use it to write a paper about it] :: nil);

  (* XXX screenshot of paper *)

  diagram-slide (slide
                 with BACKGROUND = "emacs-grey.png"
                 with TITLE-FONT-SIZE = 80.0
                 with TITLE-FONT-COLOR = 0xFFFF90FF
                 with TOP-MARGIN = inch 2.0
                 with CONTENT-START-Y = inch 2.75)
  [Here is what [it[this]] slide looks like]
  (image-load "self.png");

  just-image "code.png";
  just-image "code-self.png";

  diagram-slide (slide
                 with TITLE-FONT-SIZE = 80.0
                 with TOP-MARGIN = inch 2.0
                 with CONTENT-START-Y = inch 2.75)
  [Boxes and glue]
  (image-load "algorithm-dark.png");

  let
    val YPOS = inch 0.9
  in
    combo-slide slide
    (TextBox { x = DEFAULT-LEFT-MARGIN,
               y = YPOS,
               width = inch 9.0,
               text = [Here is an example of applying the boxes
                       and glue algorithm to this very text. Most
                       of the break points lead to extremely long
                       or short lines, so only a small region
                       is of any interest. But those details
                       matter.] } ::
     Image { img = image-load "boxes-and-glue-matrix.png",
             x = pixel 900.0,
             y = YPOS -. 36.0,
             width = NONE } ::
     nil)
  end;

  diagram-slide (slide
                 with TITLE-FONT-SIZE = 80.0
                 with TOP-MARGIN = inch 2.0
                 with CONTENT-START-Y = inch 2.75)
  [Boxes and LLMers Glue]
  (image-load "algorithm2-dark.png");

  (* Maybe I want this to loop? *)
  just-video slide "comparison.mp4";

  (* Can drop this *)
  bullet-slide slide [Additional features]
  ([Achievement system] ::
   three-d { font-name = font-regular PALATINO,
             font-size = 72.0,
             width = 40.0, height = 72.0, text = "3D text" } ::
   [Bibliography database] ::
   nil);

  just-image "achievement-screenshot.png";

  (* TODO: Future work: Acting on world, 1,000,000 *)

  text-slide slide [Conclusion]
  (justify-all
   [In this talk—and [it[with]] this talk—I presented BoVeX, a new computer
    typesetting system. It follows the tradition TeX, but with modern amenities
    such as requiring over 128 gigabytes of RAM.
    Though some may consider the addition of AI features to TeX to be an
    unnecessary perversion,
    I find this[box {(Box) glue-break-penalty = -1000000.0,
                     width = 0.0 } []]use of LLMs to be
    [it[fully justified]].]);

end
