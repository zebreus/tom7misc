(*   -*- electric-indent-local-mode: nil -*- *)
let
  import "stdlib.bovex"
  import "layout.bovex"
  import "cite.bovex"
  import "paper.bib"

  (* slides info *)
  object TalkInfo of { }

  (* do REPHRASE-ALL := SOME 50 *)
  do REPHRASE-ALL := NONE
  do NO-REPHRASE := true

  val tt = fixedersys

  (* 26 2/3 inches wide, 15 inches tall. *)
  val SLIDE-WIDTH = pixel 1920.0
  val SLIDE-HEIGHT = pixel 1080.0

  val current-page = ref 0
  fun next-slide () = current-page := !current-page + 1

  val image-cache : (string, image-handle) map ref =
    ref (map-empty string-compare)
  fun image-load-cache (f : string) : image-handle =
    case map-find (!image-cache, f) of
      SOME img => img
    | NONE =>
        let
          val img = image-load f
        in
          image-cache := map-insert (!image-cache, f, img);
          img
        end

  fun fullscreen-video src =
    sticker {(Sticker) x = 0.0, y = 0.0,
             video-width = SLIDE-WIDTH,
             video-height = SLIDE-HEIGHT,
             video = src } []

  fun exact-image-at { x : int, y : int, img = img as (Image img-handle) } =
    let
      val { width = pixel-width, height = pixel-height } = image-size img
    in
      sticker {(Sticker) x = int-to-float x, y = int-to-float y,
               img = img-handle,
               img-width = int-to-float pixel-width,
               img-height = int-to-float pixel-height } []
    end

  fun image-sticker { img = img as (Image img-handle),
                      x : float, y : float, width : float } =
    let
      (* Compute height from image native dimensions. *)
      val { width = pixel-width, height = pixel-height } = image-size img
      val ratio : float = pixel-width / pixel-height
      val height = width /. ratio
  in
    sticker {(Sticker) x = x, y = y,
             img = img-handle, img-width = width, img-height = height} []
  end

  (* Place properly kerned text, but with no wrapping. *)
  fun text-sticker { x, y } lay =
    let
      val lay = layout-map-text normalize-whitespace lay
      val boxes = get-boxes lay

      (* Turn the line into a sticker, ignoring its width/height *)
      fun stick-line (line : layout) : layout =
        case layoutcase line of
          Node (BOX, attrs, children) =>
            sticker (attrs without (Box)width
                     without (Box)height
                     with x = 0.0
                     with y = 0.0) (layout-concat children)
        | _ => fail "expected box containing the line's stickers"

    in
      (* Hack: "infinite" line width. *)
      case pack-boxes-horiz (BEST, LEFT-JUSTIFIED, 9999999999.0, boxes) of
        (badness-ignored, line :: nil) =>
          let
            val s = stick-line (stick-horizontally line)
          in
            (* debug-print-doc s; *)
            sticker {(Sticker) x = x, y = y } s
          end
      | (_, nil) =>
          (* Empty title ok. *)
          []
      | _ => fail ("Expected just one line when packing boxes on " ^
                   "an 'infinite' line.")
    end

  fun centered-text-sticker { x, y, width } lay =
    let
      val lay = layout-map-text normalize-whitespace lay
      val boxes = get-boxes lay

      (* Turn the line into a sticker, ignoring its width/height *)
      fun stick-line (line : layout) : layout =
        case layoutcase line of
          Node (BOX, attrs, children) =>
            sticker (attrs without (Box)width
                     without (Box)height
                     with x = 0.0
                     with y = 0.0) (layout-concat children)
        | _ => fail "expected box containing the line's stickers"

    in
      case pack-boxes-horiz (BEST, CENTERED, width, boxes) of
        (badness-ignored, lines) =>
          let
            val lines = layout-concat (list-map stick-horizontally lines)

            (* do debug-print-doc lines *)
          in
            sticker {(Sticker) x = x, y = y }
            (stick-line (stick-vertically (0.0, lines)))
          end
    end

  datatype element =
    Title of layout
    | Bullets of layout list
    | Image of { img : image-handle,
                 x : float,
                 y : float,
                 width : float option }

  (* val BULLET-COLOR = 0x000066FF *)
  val BULLET-COLOR = 0xAAFFAAFF

  object Slide of
    {
     BACKGROUND : string,

     TITLE-FONT-SIZE : float,
     LEFT-MARGIN : float,
     TOP-MARGIN : float,
     CONTENT-START-Y : float,
     QUOTE-FONT-SIZE : float,
     PARAGRAPH-VSPACE-BOTTOM : float,

     BODY-FONT-SIZE: float,
     BULLET-FONT-SIZE : float,
     BULLET-LINE-GAP : float,

     CONTENT-WIDTH : float,
     (* generic space between e.g. columns *)
     GAP : float,
     MONOSPACE-FONT-SIZE : float,

     TITLE-FONT-COLOR: int,
     BODY-FONT-COLOR: int
     }

  type slide-props =
    {
     BACKGROUND-IMAGE : image-handle option,

     TITLE-FONT-SIZE : float,
     LEFT-MARGIN : float,
     TOP-MARGIN : float,
     CONTENT-START-Y : float,

     BODY-FONT-SIZE : float,
     QUOTE-FONT-SIZE : float,
     PARAGRAPH-VSPACE-BOTTOM : float,

     BULLET-FONT-SIZE : float,
     BULLET-LINE-GAP : float,

     CONTENT-WIDTH: float,
     MONOSPACE-FONT-SIZE : float,
     GAP : float,

     TITLE-FONT-COLOR: int,
     BODY-FONT-COLOR: int
     }

  val DEFAULT-LEFT-MARGIN = inch 2.0
  val DEFAULT-TOP-MARGIN = inch 2.0

  fun slide-props (s : obj) : slide-props =
    let
      (* PERF could cache these,
         since we often use a background many times. *)

      val BACKGROUND-IMAGE =
        case s of
          {(Slide) BACKGROUND = bg } =>
            (if string-ends-with ".png" bg
             then
               SOME (image-load-cache bg)
             else
               let in
                 print ("Unknown background expression: " ^ bg ^ "\n");
                 NONE
               end)
        | _ => NONE

      val TITLE-FONT-SIZE =
        case s of {(Slide) TITLE-FONT-SIZE = tfs } => tfs | _ => point 136.0
      val LEFT-MARGIN =
        case s of {(Slide) LEFT-MARGIN = lm } => lm | _ => DEFAULT-LEFT-MARGIN
      val TOP-MARGIN =
        case s of {(Slide) TOP-MARGIN = tm } => tm | _ => DEFAULT-TOP-MARGIN

      val CONTENT-START-Y =
        case s of {(Slide) CONTENT-START-Y = csy } => csy
      | _ => TOP-MARGIN +. TITLE-FONT-SIZE *. 1.25

      val CONTENT-WIDTH =
        case s of {(Slide) CONTENT-WIDTH = cw } => cw
          | _ => SLIDE-WIDTH -. (2.0 *. LEFT-MARGIN)

      val QUOTE-FONT-SIZE =
        case s of {(Slide) QUOTE-FONT-SIZE = tm } => tm | _ => point 70.0

      val PARAGRAPH-VSPACE-BOTTOM =
        case s of {(Slide) PARAGRAPH-VSPACE-BOTTOM = pvb } => pvb
      | _ => point 36.0


      val BODY-FONT-SIZE =
        case s of {(Slide) BODY-FONT-SIZE = bfs } => bfs | _ => point 72.0

      val BULLET-FONT-SIZE =
        case s of {(Slide) BULLET-FONT-SIZE = bfs } => bfs | _ => point 72.0
      val BULLET-LINE-GAP =
        case s of {(Slide) BULLET-LINE-GAP = blg } => blg
      | _ => point 36.0

      val GAP =
        case s of {(Slide) GAP = g } => g
      | _ => point 36.0

      val MONOSPACE-FONT-SIZE =
        case s of {(Slide) MONOSPACE-FONT-SIZE = mfs } => mfs
          | _ => point 32.0

      val BODY-FONT-COLOR =
        case s of {(Slide) BODY-FONT-COLOR = bfc } => bfc
          | _ => 0xFFFFFFFF

      val TITLE-FONT-COLOR =
        case s of {(Slide) TITLE-FONT-COLOR = tfc } => tfc
          | _ => 0xFFFFAAFF

    in
      { BACKGROUND-IMAGE = BACKGROUND-IMAGE,
        TITLE-FONT-SIZE = TITLE-FONT-SIZE,
        LEFT-MARGIN = LEFT-MARGIN,
        TOP-MARGIN = TOP-MARGIN,
        CONTENT-START-Y = CONTENT-START-Y,
        QUOTE-FONT-SIZE = QUOTE-FONT-SIZE,
        PARAGRAPH-VSPACE-BOTTOM = PARAGRAPH-VSPACE-BOTTOM,
        BODY-FONT-SIZE = BODY-FONT-SIZE,
        BULLET-FONT-SIZE = BULLET-FONT-SIZE,
        BULLET-LINE-GAP = BULLET-LINE-GAP,
        CONTENT-WIDTH = CONTENT-WIDTH,
        MONOSPACE-FONT-SIZE = MONOSPACE-FONT-SIZE,
        GAP = GAP,
        TITLE-FONT-COLOR = TITLE-FONT-COLOR,
        BODY-FONT-COLOR = BODY-FONT-COLOR
        } : slide-props
    end

  fun default-text lay =
    let
      open slide-props {(Slide) }
    in
      (size BODY-FONT-SIZE
       (color BODY-FONT-COLOR
         (palatino
          lay)))
    end

  fun add-background-image NONE = ()
    | add-background-image (SOME img) =
      output
      (!current-page,
       exact-image-at { x = 0, y = 0, img = img })

  fun add-title props title =
    let
      open props : slide-props
    in
      output (!current-page,
              text-sticker { x = LEFT-MARGIN, y = TOP-MARGIN }
              (size TITLE-FONT-SIZE
               (color TITLE-FONT-COLOR
                (b
                 (palatino
                  title)))))
    end

  datatype element =
    Title of layout
    | Bullets of layout list
    | Image of { img : image-handle,
                 x : float,
                 y : float,
                 width : float option }
    | TextBox of { x : float,
                   y : float,
                   width : float,
                   text : layout }

  fun add-textbox props { x : float,
                          y : float,
                          width : float,
                          text : layout } =
    let
      open props : slide-props

      val xpos = x
      val ypos = ref y

      fun add-text lay =
        let
          val lay =
            span {(Span) font-size = BODY-FONT-SIZE,
                  font-face = font-family PALATINO,
                  font-color = BODY-FONT-COLOR }
            (layout-map-text normalize-whitespace lay)

          val lines = pack-one-paragraph width lay
          val lines : layout list = list-map stick-horizontally lines
          val num-lines = list-length lines

        in
          output
          (!current-page,
           box-stick-at { x = xpos, y = !ypos }
           (stick-vertically (0.0, layout-concat lines)));

          (* XXX *)
          ypos := !ypos +. BODY-FONT-SIZE *. int-to-float num-lines +.
          BULLET-LINE-GAP;
        end

    in
      add-text text
    end


  fun add-bullets props { x : float,
                          y : float,
                          width : float,
                          bullets : layout list } =
    let
      open props : slide-props

      val xpos = x
      val ypos = ref y
      fun add-bullet lay =
        let
          val lay =
            palatino
            (size BULLET-FONT-SIZE
             (color BODY-FONT-COLOR
              (layout-map-text normalize-whitespace lay)))
          val boxes = get-boxes lay
          val (badness, lines : layout list) =
            pack-boxes-horiz (BEST, LEFT-JUSTIFIED, width, boxes)
          do emit-badness badness
          val lines : layout list = list-map stick-horizontally lines

          val num-lines = list-length lines
        in
          output
          (!current-page,
           box-stick-at { x = xpos, y = !ypos }
           (stick-vertically (0.0, layout-concat lines)));

          (* output a bullet picture too *)
          output
          (!current-page,
           sticker {(Sticker)
                    x = xpos -. 64.0, y = !ypos +. 16.0,
                    font-name = font-bold PALATINO,
                    font-size = BULLET-FONT-SIZE,
                    font-color = BULLET-COLOR } [ * ]);

          ypos := !ypos +. BULLET-FONT-SIZE *. int-to-float num-lines +.
          BULLET-LINE-GAP;
        end
    in
      list-app add-bullet bullets
    end

  fun combo-slide slide (elts : element list) =
    let
      val props = slide-props slide
      open props

      val CONTENT-WIDTH =
        case list-find (fn Image _ => true | _ => false) elts of
          SOME (Image {x, y, width, img }) => (x -. GAP)
        | NONE => CONTENT-WIDTH

      fun add-elt (Title title) =
        add-title props title
        | add-elt (Bullets bull) =
        add-bullets props { x = LEFT-MARGIN,
                            y = CONTENT-START-Y,
                            width = CONTENT-WIDTH,
                            bullets = bull }
        | add-elt (Image { img, x, y, width }) =
        output
        (!current-page,
         (case width of
            NONE => exact-image-at { x = round x, y = round y, img = img }
          | SOME w => image-sticker { img = img, x = x, y = y, width = w }))
        | add-elt (TextBox { x, y, width, text }) =
        add-textbox props { x = x, y = y, width = width, text = text }

    in
      add-background-image BACKGROUND-IMAGE;

      list-app add-elt elts;

      next-slide ()
    end

  fun bullet-slide slide title bullets =
    let
      val props = slide-props slide
      open props : slide-props
    in
      add-background-image BACKGROUND-IMAGE;

      add-title props title;

      add-bullets props { x = LEFT-MARGIN,
                          y = CONTENT-START-Y,
                          width = CONTENT-WIDTH,
                          bullets = bullets };

      next-slide()
    end

  fun text-slide slide title text =
    let
      val props = slide-props slide
      open props : slide-props
    in
      add-background-image BACKGROUND-IMAGE;
      add-title props title;

      add-textbox props { x = LEFT-MARGIN,
                          y = CONTENT-START-Y,
                          width = CONTENT-WIDTH,
                          text = text };

      next-slide()
    end

  fun two-column-slide slide title text1 text2 =
    let
      val props = slide-props slide
      open props : slide-props

      val xpos1 = LEFT-MARGIN
      val gap = inch 1.0
      val COLUMN-WIDTH = (CONTENT-WIDTH -. gap) *. 0.5
      val xpos2 = LEFT-MARGIN +. COLUMN-WIDTH +. gap

    in
      add-background-image BACKGROUND-IMAGE;
      add-title props title;

      add-textbox props { x = xpos1, y = CONTENT-START-Y,
                          width = COLUMN-WIDTH,
                          text = text1 };
      add-textbox props { x = xpos2, y = CONTENT-START-Y,
                          width = COLUMN-WIDTH,
                          text = text2 };
      next-slide()
    end



  fun quote-slide slide title lay =
    let
      val props = slide-props slide
      open props : slide-props

      val xpos = LEFT-MARGIN
      val ypos = ref CONTENT-START-Y
      val COLUMN-WIDTH = CONTENT-WIDTH

      val body = span {(Span) font-size = QUOTE-FONT-SIZE,
                       font-face = font-family PALATINO,
                       font-color = BODY-FONT-COLOR,
                       font-italic = true } lay

      fun process p =
        let
          val p = (layout-map-text normalize-whitespace p)
        in
          process-paragraph (COLUMN-WIDTH, PARAGRAPH-VSPACE-BOTTOM, p)
        end

      val paras : paragraph list =
        list-concat (list-map process (get-paragraphs (body :: nil)))

      (*
      do print ("There are " ^ int-to-string (list-length paras) ^
                " paragraphs\n")
      *)

      val pboxes =
        list-map (fn (Paragraph { lines }) =>
                  stick-vertically (0.0, layout-concat lines ))
        paras

    in
      add-background-image BACKGROUND-IMAGE;

      add-title props title;

      output
      (!current-page,
       box-stick-at { x = xpos, y = !ypos }
       (stick-vertically (0.0, layout-concat pboxes)));

      next-slide()
    end

  fun title-slide slide title author venue =
    let
      val props = slide-props slide
      open props : slide-props

      fun title-text lay =
        span {(Span)
              font-bold = true,
              font-color = TITLE-FONT-COLOR,
              font-size = TITLE-FONT-SIZE} (palatino lay)
    in
      add-background-image BACKGROUND-IMAGE;

      output
      (!current-page,
       centered-text-sticker { x = 0.0, y = inch 6.0, width = SLIDE-WIDTH }
       (title-text title));

      output
      (!current-page,
       centered-text-sticker { x = 0.0, y = inch 8.0, width = SLIDE-WIDTH }
       (title-text author));

      output
      (!current-page,
       centered-text-sticker { x = 0.0, y = inch 12.0, width = SLIDE-WIDTH }
       (title-text venue));

      next-slide()
    end

  (* Titled slide with a single centered image on it. *)
  fun diagram-slide slide title img =
    let
      val props = slide-props slide
      open props : slide-props
      val { width, height } = image-size img
      val content-height = SLIDE-HEIGHT -. CONTENT-START-Y
      val IMG-PAD-TOP = CONTENT-START-Y +.
        (content-height -. int-to-float height) *. 0.5
      val IMG-PAD-LEFT =
        (SLIDE-WIDTH -. int-to-float width) *. 0.5
    in
      add-background-image BACKGROUND-IMAGE;
      add-title props title;
      output
      (!current-page,
       exact-image-at { x = round IMG-PAD-LEFT,
                        y = round IMG-PAD-TOP,
                        img = img});
      next-slide()
    end

  fun monospace-slide slide title body =
    let
      val props = slide-props slide
      open props : slide-props
    in
      add-background-image BACKGROUND-IMAGE;

      add-title props title;

      output
      (!current-page,
       box-stick-at { x = LEFT-MARGIN, y = CONTENT-START-Y }
       (monospace-block-ext { left-indent = 0.0,
                              line-spacing = 2.0,
                              width = CONTENT-WIDTH,
                              font-size = MONOSPACE-FONT-SIZE,
                              attrs = {(Span) font-color = BODY-FONT-COLOR} }
        body));

      next-slide()
    end

  (* The whole slide is just this image exactly. *)
  fun just-image filename =
    let
      val img = image-load filename
    in
      output
      (!current-page,
       exact-image-at { x = 0, y = 0, img = img});

      next-slide()
    end

  (* The whole slide is this full-screen video. *)
  fun just-video slide src =
    let
      val props = slide-props slide
      open props : slide-props
    in
      (* Adding the background image helps prevent a flash
         of white when unloading the video. *)
      add-background-image BACKGROUND-IMAGE;

      output
      (!current-page,
       fullscreen-video src);

      next-slide()
    end

  fun on-previous-slide layout =
    output (!current-page - 1, layout)

  val slide = {(Slide) BACKGROUND = "sunset-bg.png" }

  (* Currently need to tell it the dimensions, but we could easily
     get them with get-boxes or something like that. *)
  fun three-d { font-name, font-size, width, height, text } =
    box {(Box) width = width, height = height }
    (sticker {(Sticker)
               x = 6.0,
               y = 1.0,
              font-color = rgba(0, 180, 255, 255),
              font-name = font-name,
              font-size = font-size } (layout text) ^^
     sticker {(Sticker)
              x = 0.0,
              y = 0.0,
              font-color = rgba(255, 0, 0, 200),
              font-name = font-name,
              font-size = font-size } (layout text))

  fun get-box lay =
    let
      val lay = layout-map-text normalize-whitespace lay
      val boxes = get-boxes lay
    in
      (* Hack: "infinite" line width. *)
      case pack-boxes-horiz (BEST, LEFT-JUSTIFIED, 9999999999.0, boxes) of
        (badness-ignored, line :: nil) => stick-horizontally line
      | (_, nil) => box {(Box) width = 0.0, height = 0.0} []
      | _ => fail ("Expected just one line when packing boxes on " ^
                   "an 'infinite' line.")
    end

  fun zigzag zig lay =
    case layoutcase (get-box lay) of
      Node (BOX, attrs as {(Box) width, height}, ch) =>
        let
          val y-offset = height *. -0.15
          val d =
            box attrs
            (layout-concat
             (ch @
              (if zig then
                  (image-sticker
                   { img = image-load-cache "red-underline.png",
                     x = 0.0, y = y-offset, width = width } :: nil)
               else nil)
              ))
        in
          d
        end
    | _ =>
        let in
          debug-print-doc lay;
          fail "Expected box with width/height from get-box"
        end

  fun em lay = color 0xCCCCFFFF lay
in

