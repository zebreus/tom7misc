  let
    val YPOS = inch 2.0
  in
    combo-slide slide
    ((* Title [Corporate Preso] :: *)
     TextBox { x = DEFAULT-LEFT-MARGIN,
               y = YPOS,
               width = inch 9.0,
               text = [Here is an example of applying the boxes
                       and glue algorithm to this very text. Most
                       of the break points lead to extremely long
                         or short lines, so only a small region
                         is of any interest. But those details
                         matter.] } ::
     Image { img = image-load "boxes-and-glue-matrix.png",
