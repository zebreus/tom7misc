(defun code-format-paragraph ()
  "Either use eglot-format on the selected region, or set a region to the 'current paragraph' and then format it."
  (interactive "")

  (if (region-active-p)
      ;; use the region
      (eglot-format (region-beginning) (region-end))
      ;; deduce a region
      ;; this comes from c-fill-paragraph
      (let ((pos (point))
            (beg nil)
            (end nil))
        (progn
          (save-excursion
            (unless (c-safe (backward-char)
                            (forward-paragraph)
                            (>= (point) pos))
              (goto-char pos)
              (forward-paragraph))
            (setq end (point-marker)))
          (save-excursion
            (unless (c-safe (forward-char)
                            (backward-paragraph)
                            (<= (point) pos))
              (goto-char pos)
              (backward-paragraph))
            (setq beg (point)))
          (if (and beg end)
              (progn
                (message "formatting...")
                (eglot-format beg end))
              (message "unable to find paragraph?"))
          ))))

;; One annoyance of eglot quickfix is that it will use absolute paths
;; to includes that are already in the include path. The most common
;; one for me is headers from my cc-lib. There doesn't seem to be a clean
;; way to fix this with configuration, so I just run a global search
;; and replace after the command.
(defun tom7-eglot-quickfix ()
  (interactive)
  (call-interactively 'eglot-code-action-quickfix)
  (save-excursion
    (let ((replace-from "#include \"c:/code/sf_svn/cc-lib/"))
      (goto-char (point-min))
      (while (search-forward replace-from nil t)
        (replace-match "#include \"" nil t)))
    ;;; and on a mac...
    (let ((replace-from "#include \"/Users/twm/tom7misc/cc-lib/"))
      (goto-char (point-min))
      (while (search-forward replace-from nil t)
        (replace-match "#include \"" nil t)))
    ))

